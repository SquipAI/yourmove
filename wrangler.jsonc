{
  "compatibility_date": "2026-05-07",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "yourmove",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "59fc708e9ae048e8839b3b152b744680",
    },
  ],
  "observability": {
    "enabled": true,
  },
}
