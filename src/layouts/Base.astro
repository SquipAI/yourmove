---
import "@styles/global.css";
import BaseHead from "@components/layout/BaseHead.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { LOCALES, DEFAULT_LOCALE, HREFLANG } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { getNavigation } from "@lib/queries";
import type { NavItem, NavItemRaw } from "@lib/types";

interface Props {
  title: string;
  description: string;
  lang?: Locale;
  canonical?: string;
  alternateUrls?: Record<Locale, string>;
  ogImage?: string;
  ogType?: "website" | "article";
}

const { title, description, lang = DEFAULT_LOCALE, canonical, ogImage, ogType } = Astro.props;

// Derive alternateUrls from the current path if not passed explicitly.
// Strips locale prefix (/es/privacy → privacy) and builds per-locale URLs.
// Adding a new locale only requires updating LOCALES in config.
const alternateUrls: Record<Locale, string> = Astro.props.alternateUrls ?? (() => {
  const nonDefault = LOCALES.filter((l) => l !== DEFAULT_LOCALE);
  const slug = Astro.url.pathname
    .replace(new RegExp(`^/(${nonDefault.join("|")})(\/|$)`), "")
    .replace(/^\//, "");
  return Object.fromEntries(
    LOCALES.map((l) => [l, `${Astro.url.origin}${slug ? getRelativeLocaleUrl(l, slug) : getRelativeLocaleUrl(l)}`]),
  ) as Record<Locale, string>;
})();

const PAGE_PATHS: Partial<Record<NavItemRaw["targetType"], string>> = {
  home: "",
  blog: "blog",
  privacy: "privacy",
  terms: "terms",
};

function resolveNavItems(raw: NavItemRaw[] | null): NavItem[] {
  if (!raw) return [];
  return raw.flatMap(({ label, targetType, externalUrl }) => {
    if (externalUrl) return [{ label, href: externalUrl, external: true }];
    if (!(targetType in PAGE_PATHS)) return [];
    const path = PAGE_PATHS[targetType]!;
    const href = path ? getRelativeLocaleUrl(lang, path) : getRelativeLocaleUrl(lang);
    return [{ label, href }];
  });
}

const [headerRaw, footerRaw] = await Promise.all([
  getNavigation("nav-header"),
  getNavigation("nav-footer"),
]);
const headerNavItems = resolveNavItems(headerRaw);
const footerNavItems = resolveNavItems(footerRaw);
---

<!doctype html>
<html lang={HREFLANG[lang]}>
  <head>
    <BaseHead
      title={title}
      description={description}
      lang={lang}
      canonical={canonical}
      alternateUrls={alternateUrls}
      ogImage={ogImage}
      ogType={ogType}
    />
    <slot name="head" />
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <Header lang={lang} alternateUrls={alternateUrls} navItems={headerNavItems} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} navItems={footerNavItems} />
  </body>
</html>
