---
import "@styles/global.css";
import BaseHead from "@components/layout/BaseHead.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import { DEFAULT_LOCALE, HREFLANG } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { buildSiteChrome } from "@lib/siteChrome";
import { defaultAlternateUrls } from "@lib/alternateUrls";

interface Props {
  title: string;
  description: string;
  lang?: Locale;
  canonical?: string;
  alternateUrls?: Record<Locale, string>;
  ogImage?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description,
  lang = DEFAULT_LOCALE,
  canonical,
  ogImage,
  ogType,
} = Astro.props;

const alternateUrls =
  Astro.props.alternateUrls ?? defaultAlternateUrls(Astro.url);
const chrome = await buildSiteChrome(lang);
---

<!doctype html>
<html lang={HREFLANG[lang]}>
  <head>
    <BaseHead
      title={title}
      description={description}
      lang={lang}
      canonical={canonical}
      alternateUrls={alternateUrls}
      ogImage={ogImage}
      ogType={ogType}
    />
    <slot name="head" />
  </head>
  <body>
    <Header
      lang={lang}
      alternateUrls={alternateUrls}
      tools={chrome.toolsColumn}
      flatLinks={chrome.flatLinks}
    />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer
      lang={lang}
      tagline={chrome.footer.tagline}
      toolsColumn={chrome.toolsColumn}
      columns={chrome.footer.columns}
    />
  </body>
</html>
