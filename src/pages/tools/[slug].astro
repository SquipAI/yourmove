---
import AppPage from "@components/tools/pages/AppPage.astro";
import { getAppPage, getAllAppSlugs } from "@lib/queries";

export async function getStaticPaths() {
  const slugs = await getAllAppSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const app = await getAppPage(slug!);
---

<AppPage app={app!} />
