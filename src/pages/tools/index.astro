---
import ToolsPage from "@components/tools/pages/ToolsPage.astro";
import {
  getToolsPage,
  getFeaturedTools,
  getCategoriesWithTools,
  getAppsWithTools,
  TOOLS_FEATURED_COUNT,
} from "@lib/queries";

const [page, featured, categories, apps] = await Promise.all([
  getToolsPage(),
  getFeaturedTools(TOOLS_FEATURED_COUNT),
  getCategoriesWithTools(),
  getAppsWithTools(),
]);
---

<ToolsPage {page} {featured} {categories} {apps} />
