---
import ToolsPage from "@components/tools/pages/ToolsPage.astro";
import {
  getToolsPage,
  getFeaturedTools,
  getCategoriesWithTools,
  getAppsWithTools,
  TOOLS_FEATURED_COUNT,
} from "@lib/queries";
import { getNonDefaultLocalePaths } from "@i18n/utils";
import type { Locale } from "@i18n/config";

export function getStaticPaths() {
  return getNonDefaultLocalePaths();
}

const lang = Astro.params.lang as Locale;

const [page, featured, categories, apps] = await Promise.all([
  getToolsPage(lang),
  getFeaturedTools(TOOLS_FEATURED_COUNT, lang),
  getCategoriesWithTools(lang),
  getAppsWithTools(lang),
]);
---

<ToolsPage {page} {featured} {categories} {apps} {lang} />
