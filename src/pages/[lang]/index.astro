---
import HomePage from "@components/home/HomePage.astro";
import { getHome } from "@lib/queries";
import { getNonDefaultLocalePaths } from "@i18n/utils";
import type { Locale } from "@i18n/config";

export function getStaticPaths() {
  return getNonDefaultLocalePaths();
}

const lang = Astro.params.lang as Locale;
const home = await getHome(lang);
---

<HomePage {home} {lang} />
