---
import PostPage from "@components/blog/pages/PostPage.astro";
import {
  getPostBySlug,
  getRelatedPosts,
  getAllPostSlugs,
  getHome,
  getBlogPage,
} from "@lib/queries";
import { getNonDefaultLocalePaths } from "@i18n/utils";
import type { Locale } from "@i18n/config";

export async function getStaticPaths() {
  const locales = getNonDefaultLocalePaths().map(
    (p) => p.params.lang as Locale,
  );
  const slugs = await getAllPostSlugs();
  return locales.flatMap((lang) =>
    slugs.map((slug) => ({ params: { lang, slug } })),
  );
}

const lang = Astro.params.lang as Locale;
const { slug } = Astro.params;
const [post, home, blog] = await Promise.all([
  getPostBySlug(slug!, lang),
  getHome(lang),
  getBlogPage(lang),
]);
const related = await getRelatedPosts(post!._id, post!.tagIds, lang);
---

<PostPage
  post={post!}
  {related}
  homeTitle={home.title}
  blogTitle={blog.title}
  {lang}
/>
