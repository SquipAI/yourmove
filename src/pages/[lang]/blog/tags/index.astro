---
import TagListPage from "@components/blog/pages/TagListPage.astro";
import { getAllTagsWithCount, getBlogTagsPage } from "@lib/queries";
import { getNonDefaultLocalePaths } from "@i18n/utils";
import type { Locale } from "@i18n/config";

export function getStaticPaths() {
  return getNonDefaultLocalePaths();
}

const lang = Astro.params.lang as Locale;
const [tags, page] = await Promise.all([
  getAllTagsWithCount(lang),
  getBlogTagsPage(lang),
]);
---

<TagListPage {tags} {page} {lang} />
