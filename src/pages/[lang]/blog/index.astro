---
import BlogPage from "@components/blog/pages/BlogPage.astro";
import { getBlogPage, getLatestPosts, getFeaturedPosts, getTagsWithPostPreview, getAllTagsWithCount, BLOG_LATEST_COUNT, BLOG_FEATURED_COUNT } from "@lib/queries";
import { getNonDefaultLocalePaths } from "@i18n/utils";
import type { Locale } from "@i18n/config";

export function getStaticPaths() {
  return getNonDefaultLocalePaths();
}

const lang = Astro.params.lang as Locale;

const [page, latest, featured, tagSections, allTags] = await Promise.all([
  getBlogPage(lang),
  getLatestPosts(BLOG_LATEST_COUNT, lang),
  getFeaturedPosts(BLOG_FEATURED_COUNT, lang),
  getTagsWithPostPreview(lang),
  getAllTagsWithCount(lang),
]);
---

<BlogPage {page} {latest} {featured} {tagSections} {allTags} {lang} />
