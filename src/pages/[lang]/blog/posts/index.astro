---
import PostListPage from "@components/blog/pages/PostListPage.astro";
import { getAllPublishedPosts, getBlogPostsPage } from "@lib/queries";
import { getNonDefaultLocalePaths } from "@i18n/utils";
import type { Locale } from "@i18n/config";

export function getStaticPaths() {
  return getNonDefaultLocalePaths();
}

const lang = Astro.params.lang as Locale;
const [posts, page] = await Promise.all([
  getAllPublishedPosts(lang),
  getBlogPostsPage(lang),
]);
---

<PostListPage {posts} {page} {lang} />
