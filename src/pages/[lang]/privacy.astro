---
import LegalPage from "@components/legal/LegalPage.astro";
import { getLegalPage } from "@lib/queries";
import { getNonDefaultLocalePaths } from "@i18n/utils";
import type { Locale } from "@i18n/config";

export function getStaticPaths() {
  return getNonDefaultLocalePaths();
}

const lang = Astro.params.lang as Locale;
const page = await getLegalPage("privacy", lang);
---

<LegalPage {page} {lang} />
