---
import Base from "@layouts/Base.astro";
import PageHeading from "@components/shared/PageHeading.astro";
import TagCard from "@components/blog/ui/TagCard.astro";
import AppDownloadSection from "@components/shared/AppDownloadSection.astro";
import { getAllTagsWithCount, getBlogTagsPage, getAppDownload } from "@lib/queries";
import { ogImageHref } from "@lib/og/route";
import { getAllLocalePaths } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export function getStaticPaths() {
  return getAllLocalePaths();
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const [tags, page, appDownload] = await Promise.all([
  getAllTagsWithCount(lang),
  getBlogTagsPage(lang),
  getAppDownload(),
]);
---

<Base
  title={page.metaTitle}
  description={page.metaDescription}
  {lang}
  ogImage={ogImageHref(Astro.url.origin, lang, "blog/topics")}
>
  <section class="section">
    <PageHeading
      title={page.title}
      eyebrow={`${tags.length} ${t(lang, "blog.topics").toLowerCase()}`}
      subtitle={page.description}
    />
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tags.map((tag) => <TagCard {tag} {lang} />)}
    </ul>
  </section>

  <AppDownloadSection heading={page.downloadHeading} {...appDownload} {lang} />
</Base>
