---
import Base from "@layouts/Base.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import PageHeading from "@components/shared/PageHeading.astro";
import TagCard from "@components/blog/ui/TagCard.astro";
import CtaSection from "@components/shared/CtaSection.astro";
import {
  getAllTagsWithCount,
  getBlogTagsPage,
  getAppDownload,
  getNavLabels,
} from "@lib/queries";
import { collectionPageSchema, breadcrumbTrail } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { canonicalUrl } from "@lib/canonicalUrl";
import { getAllLocalePaths, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export function getStaticPaths() {
  return getAllLocalePaths();
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const [tags, page, appDownload, nav] = await Promise.all([
  getAllTagsWithCount(lang),
  getBlogTagsPage(lang),
  getAppDownload(),
  getNavLabels(lang),
]);

const origin = Astro.url.origin;
const localePath = localePathFor(lang);
const ogImage = ogImageHref(origin, lang, "blog/topics");
const schema = collectionPageSchema(
  canonicalUrl(Astro.url),
  lang,
  page.title,
  page.metaDescription,
  breadcrumbTrail(origin, lang, [
    { name: nav.home, path: "" },
    { name: nav.blog, path: "blog" },
    { name: t(lang, "blog.topics") },
  ]),
  ogImage,
  tags.map((tag) => ({
    name: tag.title,
    url: `${origin}${localePath(`blog/topics/${tag.slug}`)}`,
  })),
);
---

<Base
  title={page.metaTitle}
  description={page.metaDescription}
  {lang}
  {ogImage}
>
  <SchemaOrg slot="head" {schema} />
  <section class="section">
    <PageHeading
      title={page.title}
      eyebrow={`${tags.length} ${t(lang, "blog.topics").toLowerCase()}`}
      subtitle={page.description}
    />
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tags.map((tag) => <TagCard {tag} {lang} />)}
    </ul>
  </section>

  <CtaSection heading={page.downloadHeading} {...appDownload} {lang} />
</Base>
