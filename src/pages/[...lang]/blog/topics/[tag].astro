---
import Base from "@layouts/Base.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import PostList from "@components/blog/ui/PostList.astro";
import TagList from "@components/blog/ui/TagList.astro";
import PageHeading from "@components/shared/PageHeading.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import CtaSection from "@components/shared/CtaSection.astro";
import {
  getAllTagsWithCount,
  getAllTagPaths,
  getTagBySlug,
  getTagPosts,
  getAppDownload,
  getNavLabels,
} from "@lib/queries";
import { collectionPageSchema, breadcrumbTrail } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { canonicalUrl } from "@lib/canonicalUrl";
import { buildAlternateUrls, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export async function getStaticPaths() {
  const paths = await getAllTagPaths();
  return paths.map(({ lang, slug }) => ({
    params: { lang: lang === DEFAULT_LOCALE ? undefined : lang, tag: slug },
  }));
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const { tag: slug } = Astro.params;
if (!slug) throw new Error("Missing slug param");
const [tag, posts, allTags, appDownload, nav] = await Promise.all([
  getTagBySlug(slug, lang),
  getTagPosts(slug, lang),
  getAllTagsWithCount(lang),
  getAppDownload(),
  getNavLabels(lang),
]);
if (!tag) throw new Error(`Tag not found: ${slug} (${lang})`);
const otherTags = allTags.filter((t) => t.slug !== slug);
const count =
  posts.length === 1 ? t(lang, "blog.article") : t(lang, "blog.articles");
const alternateUrls = buildAlternateUrls(
  Astro.url.origin,
  lang,
  slug,
  tag.alternates,
  "blog/topics",
);

const origin = Astro.url.origin;
const localePath = localePathFor(lang);
const ogImage = ogImageHref(origin, lang, `blog/topics/${slug}`);
const schema = collectionPageSchema(
  canonicalUrl(Astro.url),
  lang,
  tag.title,
  tag.metaDescription,
  breadcrumbTrail(origin, lang, [
    { name: nav.home, path: "" },
    { name: nav.blog, path: "blog" },
    { name: t(lang, "blog.topics"), path: "blog/topics" },
    { name: tag.title },
  ]),
  ogImage,
  posts.map((post) => ({
    name: post.title,
    url: `${origin}${localePath(`blog/${post.slug}`)}`,
  })),
);
---

<Base
  title={tag.metaTitle}
  description={tag.metaDescription}
  {lang}
  {alternateUrls}
  {ogImage}
>
  <SchemaOrg slot="head" {schema} />
  <section class="section">
    <PageHeading
      title={`${tag.title}: *${tag.metaTitle}*`}
      eyebrow={`${posts.length} ${count}`}
      subtitle={tag.description}
    />

    <PostList {posts} {lang} priorityCount={2} />
  </section>

  <section class="section pt-0">
    <SectionHeading
      eyebrow={t(lang, "blog.explore")}
      title={t(lang, "blog.moreTopics")}
      size="sm"
    />

    <TagList tags={otherTags} {lang} />
  </section>

  <CtaSection heading={tag.downloadHeading} {...appDownload} {lang} />
</Base>
