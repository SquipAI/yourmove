---
import Base from "@layouts/Base.astro";

import PageHeading from "@components/shared/PageHeading.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import ListingSection from "@components/shared/ListingSection.astro";
import FeaturedList from "@components/blog/ui/FeaturedList.astro";
import LatestList from "@components/blog/ui/LatestList.astro";
import PostCard from "@components/blog/ui/PostCard.astro";
import SeeAllLink from "@components/blog/ui/SeeAllLink.astro";
import TagList from "@components/blog/ui/TagList.astro";
import CtaSection from "@components/shared/CtaSection.astro";

import SchemaOrg from "@components/seo/SchemaOrg.astro";
import {
  getBlogPage,
  getLatestPosts,
  getFeaturedPosts,
  getTagsWithPostPreview,
  getAllTagsWithCount,
  getPostCount,
  getAppDownload,
  getNavLabels,
  BLOG_LATEST_COUNT,
  BLOG_FEATURED_COUNT,
} from "@lib/queries";

import { collectionPageSchema, breadcrumbTrail } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { canonicalUrl } from "@lib/canonicalUrl";
import { getAllLocalePaths, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export function getStaticPaths() {
  return getAllLocalePaths();
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;

const [page, latest, featured, tagSections, allTags, postCount, appDownload, nav] =
  await Promise.all([
    getBlogPage(lang),
    getLatestPosts(BLOG_LATEST_COUNT, lang),
    getFeaturedPosts(BLOG_FEATURED_COUNT, lang),
    getTagsWithPostPreview(lang),
    getAllTagsWithCount(lang),
    getPostCount(lang),
    getAppDownload(),
    getNavLabels(lang),
  ]);

const origin = Astro.url.origin;
const localePath = localePathFor(lang);
const ogImage = ogImageHref(origin, lang, "blog");
const schema = collectionPageSchema(
  canonicalUrl(Astro.url),
  lang,
  page.title,
  page.metaDescription,
  breadcrumbTrail(origin, lang, [
    { name: nav.home, path: "" },
    { name: nav.blog },
  ]),
  ogImage,
  latest.map((post) => ({
    name: post.title,
    url: `${origin}${localePath(`blog/${post.slug}`)}`,
  })),
);
---

<Base
  title={page.metaTitle}
  description={page.metaDescription}
  {lang}
  {ogImage}
>
  <SchemaOrg slot="head" {schema} />
  <header class="section pb-section-sm md:pb-svw">
    <PageHeading title={page.title} subtitle={page.description} size="big" />
  </header>

  <section class="section pt-0">
    <h2 class="sr-only">{t(lang, "blog.featured")}</h2>
    <FeaturedList posts={featured} {lang} />
  </section>

  <ListingSection
    title={t(lang, "blog.latest")}
    size="sm"
    seeAllHref={localePath("blog/posts")}
    seeAllCount={postCount}
    {lang}
    class="bg-subtle-lighter"
  >
    <LatestList posts={latest} {lang} />
  </ListingSection>

  <section class="section">
    <SectionHeading title={t(lang, "blog.topics")} size="sm" />
    <TagList tags={allTags} {lang} class="mb-section-xs" />

    <ul
      class="gap-y-section-sm grid grid-cols-1 md:grid-cols-2 md:gap-x-10 xl:*:w-full xl:*:max-w-156"
    >
      {
        tagSections.map((section) => (
          <li class="listing-grid">
            <h3 class="text-title-xs mb-[.66em] sm:mb-[1em]">
              {section.title}
            </h3>
            <ul class="mb-4 flex flex-col gap-4 sm:max-md:flex-row">
              {section.posts.map((post) => (
                <li>
                  <PostCard
                    {post}
                    {lang}
                    level={4}
                    size="sm"
                    imageMode="right"
                    noDescription
                    meta="none"
                    headingClass="mb-0 max-w-[24ch]"
                  />
                </li>
              ))}
            </ul>
            <SeeAllLink
              href={localePath(`blog/topics/${section.slug}`)}
              {lang}
              size="sm"
            />
          </li>
        ))
      }
    </ul>
  </section>

  <CtaSection heading={page.downloadHeading} {...appDownload} {lang} />
</Base>
