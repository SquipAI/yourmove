---
import Base from "@layouts/Base.astro";

import PageHeading from "@components/shared/PageHeading.astro";
import PortableText from "@components/shared/PortableText.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import ShareButtons from "@components/shared/ShareButtons.astro";
import PostList from "@components/blog/ui/PostList.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";

import ShortLogo from "@assets/svg/ShortLogoSvg.svg";

import {
  getPostBySlug,
  getRelatedPosts,
  getAllPostPaths,
  getHome,
  getBlogPage,
} from "@lib/queries";
import { articleSchema } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { stripAccent } from "@lib/parseAccent";

import { buildAlternateUrls, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export async function getStaticPaths() {
  const paths = await getAllPostPaths();
  return paths.map(({ lang, slug }) => ({
    params: { lang: lang === DEFAULT_LOCALE ? undefined : lang, slug },
  }));
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const { slug } = Astro.params;
const [post, home, blog] = await Promise.all([
  getPostBySlug(slug!, lang),
  getHome(lang),
  getBlogPage(lang),
]);
if (!post) throw new Error(`Post not found: ${slug} (${lang})`);
const related = await getRelatedPosts(post._id, post.tagIds, lang);
const alternateUrls = buildAlternateUrls(
  Astro.url.origin,
  lang,
  slug!,
  post.alternates,
  "blog",
);

const origin = Astro.url.origin;
const pageUrl = String(Astro.url);
const localePath = localePathFor(lang);
const blogUrl = `${origin}${localePath("blog")}`;
const firstTag = post.tags[0];
const tagUrl = `${origin}${localePath(`blog/topics/${firstTag.slug}`)}`;
const ogImage = ogImageHref(origin, lang, `blog/${slug}`);

const breadcrumbsNav = [
  { name: blog.title, url: blogUrl },
  { name: firstTag.title, url: tagUrl },
];

const breadcrumbsSchema = [
  { name: home.navLabel, url: `${origin}${localePath("")}` },
  { name: blog.title, url: blogUrl },
  { name: firstTag.title, url: tagUrl },
  { name: stripAccent(post.title), url: pageUrl },
];

const published = new Date(post.createdAt);
const updated = new Date(post._updatedAt);
const isUpdated = updated.getTime() - published.getTime() > 24 * 60 * 60 * 1000;
const displayDate = isUpdated ? updated : published;
const dateFormatted = new Intl.DateTimeFormat(lang, {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(displayDate);
---

<Base
  title={post.metaTitle}
  description={post.metaDescription}
  {lang}
  {alternateUrls}
  ogType="article"
  {ogImage}
>
  <SchemaOrg
    slot="head"
    schema={articleSchema(post, pageUrl, lang, breadcrumbsSchema)}
  />

  <article class="section *:max-w-[84ch]">
    <header class="max-w-prose pb-10">
      <PageHeading
        title={post.title}
        subtitle={post.summary}
        breadcrumbs={breadcrumbsNav}
      />

      <div
        class="grid grid-cols-[auto_max-content] items-center gap-x-6 gap-y-4 border-y border-subtle/50 py-4 leading-none text-sm md:flex md:flex-row md:flex-wrap md:justify-between"
      >
        <div class="grid grid-cols-[max-content_auto] items-center gap-x-2">
          <ShortLogo class="row-span-2 fill-brand size-9" />

          <span class="tracking-eyebrow text-subtle text-xs uppercase">
            {t(lang, "blog.writtenBy")}
          </span>
          <span class="text-subtle font-medium">YourMove Team</span>
        </div>

        <span aria-hidden="true" class="text-subtle/50 hidden md:block">·</span>

        <time datetime={displayDate.toISOString()} class="text-subtle">
          {isUpdated && <span>{t(lang, "blog.updated")} </span>}{dateFormatted}
        </time>

        <span aria-hidden="true" class="text-subtle/50 hidden md:block">·</span>
        <span class="text-subtle">
          {post.readingTime} {t(lang, "blog.minRead")}
        </span>
        }

        <span aria-hidden="true" class="text-subtle/50 hidden md:block">·</span>

        <ShareButtons url={pageUrl} title={stripAccent(post.title)} {lang} />
      </div>
    </header>

    <div class="prose">
      <PortableText body={post.body ?? []} faq={post.faq} {lang} />
    </div>
  </article>

  {
    related.length > 0 && (
      <section class="section">
        <SectionHeading
          eyebrow={t(lang, "blog.keepReading")}
          title={t(lang, "blog.relatedPosts")}
          class="mb-8"
        />
        <PostList posts={related} {lang} level={3} imageMode="none" />
      </section>
    )
  }
</Base>
