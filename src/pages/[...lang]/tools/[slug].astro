---
import Base from "@layouts/Base.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import PageHeading from "@components/shared/PageHeading.astro";
import ToolList from "@components/tools/ui/ToolList.astro";
import CtaSection from "@components/shared/CtaSection.astro";
import {
  getAllAppsForBuild,
  getAppDownload,
  getNavLabels,
} from "@lib/queries";
import { collectionPageSchema, breadcrumbTrail } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { canonicalUrl } from "@lib/canonicalUrl";
import { buildAlternateUrls, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export async function getStaticPaths() {
  const apps = await getAllAppsForBuild();
  return apps.map(({ lang, slug, app }) => ({
    params: { lang: lang === DEFAULT_LOCALE ? undefined : lang, slug },
    props: { app },
  }));
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const { slug } = Astro.params;
if (!slug) throw new Error("Missing slug param");
const { app } = Astro.props;
const [appDownload, nav] = await Promise.all([
  getAppDownload(),
  getNavLabels(lang),
]);
const count =
  app.tools.length === 1 ? t(lang, "tools.tool") : t(lang, "tools.tools");
const alternateUrls = buildAlternateUrls(
  Astro.url.origin,
  lang,
  app.slug,
  app.alternates,
  "tools",
);

const origin = Astro.url.origin;
const localePath = localePathFor(lang);
const ogImage = ogImageHref(origin, lang, `tools/${slug}`);
const schema = collectionPageSchema(
  canonicalUrl(Astro.url),
  lang,
  app.title,
  app.metaDescription,
  breadcrumbTrail(origin, lang, [
    { name: nav.home, path: "" },
    { name: nav.tools, path: "tools" },
    { name: app.name },
  ]),
  ogImage,
  app.tools.map((tool) => ({
    name: tool.cardTitle ?? tool.title,
    url: `${origin}${localePath(tool.slug)}`,
  })),
);
---

<Base
  title={app.metaTitle}
  description={app.metaDescription}
  {lang}
  {alternateUrls}
  {ogImage}
>
  <SchemaOrg slot="head" {schema} />
  <section class="section">
    <PageHeading
      title={app.title}
      subtitle={app.description ?? `${app.tools.length} ${count}`}
    />

    <ToolList tools={app.tools} {lang} level={2} />
  </section>

  <CtaSection heading={app.downloadHeading} {...appDownload} {lang} />
</Base>
