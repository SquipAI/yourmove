---
import Base from "@layouts/Base.astro";

import SectionHeading from "@components/shared/SectionHeading.astro";
import AppCard from "@components/tools/ui/AppCard.astro";
import ToolList from "@components/tools/ui/ToolList.astro";
import ToolsHero from "@components/tools/ui/ToolsHero.astro";
import CtaSection from "@components/shared/CtaSection.astro";

import SchemaOrg from "@components/seo/SchemaOrg.astro";
import {
  getToolsPage,
  getFeaturedTools,
  getCategoriesWithTools,
  getAppsWithTools,
  getAppDownload,
  getNavLabels,
} from "@lib/queries";

import { collectionPageSchema } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { canonicalUrl } from "@lib/canonicalUrl";
import { getAllLocalePaths, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export function getStaticPaths() {
  return getAllLocalePaths();
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;

const [page, featured, categories, apps, appDownload, nav] = await Promise.all([
  getToolsPage(lang),
  getFeaturedTools(lang),
  getCategoriesWithTools(lang),
  getAppsWithTools(lang),
  getAppDownload(),
  getNavLabels(lang),
]);

const origin = Astro.url.origin;
const localePath = localePathFor(lang);
const pageUrl = canonicalUrl(Astro.url);
const ogImage = ogImageHref(origin, lang, "tools");
const schema = collectionPageSchema(
  pageUrl,
  lang,
  page.title,
  page.metaDescription,
  [
    { name: nav.home, url: `${origin}${localePath("")}` },
    { name: nav.tools },
  ],
  ogImage,
  featured.map((tool) => ({
    name: tool.cardTitle ?? tool.title,
    url: `${origin}${localePath(tool.slug)}`,
  })),
);
---

<Base
  title={page.metaTitle}
  description={page.metaDescription}
  {lang}
  {ogImage}
>
  <SchemaOrg slot="head" {schema} />
  <ToolsHero {page} {categories} {apps} {lang} />

  {
    featured.length > 0 && (
      <section class="section pt-section-sm lg:pt-section-xs">
        <h2 class="sr-only">{t(lang, "tools.top")}</h2>
        <ToolList tools={featured} {lang} level={2} />
      </section>
    )
  }

  <section id="by-app" class="section bg-subtle-lighter">
    <SectionHeading title={t(lang, "tools.browseByApp")} />
    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        apps.map((app) => (
          <li>
            <AppCard {app} {lang} level={3} />
          </li>
        ))
      }
    </ul>
  </section>

  {
    categories.map((cat) => (
      <section
        id={`category-${cat._id}`}
        class="section not-last:pb-section-xs"
      >
        <SectionHeading
          title={cat.title}
          subtitle={cat.description}
          size="sm"
        />
        <ToolList tools={cat.tools} {lang} level={3} />
      </section>
    ))
  }

  <CtaSection heading={page.downloadHeading} {...appDownload} {lang} />
</Base>
