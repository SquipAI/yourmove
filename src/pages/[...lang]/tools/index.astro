---
import Base from "@layouts/Base.astro";

import SectionHeading from "@components/shared/SectionHeading.astro";
import AppCard from "@components/tools/ui/AppCard.astro";
import ToolList from "@components/tools/ui/ToolList.astro";
import ToolsHero from "@components/tools/ui/ToolsHero.astro";
import AppDownloadSection from "@components/shared/AppDownloadSection.astro";

import {
  getToolsPage,
  getFeaturedTools,
  getCategoriesWithTools,
  getAppsWithTools,
  getAppDownload,
} from "@lib/queries";

import { ogImageHref } from "@lib/og/route";
import { getAllLocalePaths } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";

export function getStaticPaths() {
  return getAllLocalePaths();
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;

const [page, featured, categories, apps, appDownload] = await Promise.all([
  getToolsPage(lang),
  getFeaturedTools(lang),
  getCategoriesWithTools(lang),
  getAppsWithTools(lang),
  getAppDownload(),
]);
---

<Base
  title={page.metaTitle}
  description={page.metaDescription}
  {lang}
  ogImage={ogImageHref(Astro.url.origin, lang, "tools")}
>
  <ToolsHero {page} {categories} {apps} {lang} />

  {
    featured.length > 0 && (
      <section class="section pt-section-sm lg:pt-section-xs">
        <h2 class="sr-only">{t(lang, "tools.top")}</h2>
        <ToolList tools={featured} {lang} level={2} />
      </section>
    )
  }

  <section id="by-app" class="section bg-subtle-lighter">
    <SectionHeading title={t(lang, "tools.browseByApp")} />
    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        apps.map((app) => (
          <li>
            <AppCard {app} {lang} level={3} />
          </li>
        ))
      }
    </ul>
  </section>

  {
    categories.map((cat) => (
      <section
        id={`category-${cat._id}`}
        class="section not-last:pb-section-xs"
      >
        <SectionHeading
          title={cat.title}
          subtitle={cat.description}
          size="sm"
        />
        <ToolList tools={cat.tools} {lang} level={3} />
      </section>
    ))
  }

  <AppDownloadSection heading={page.downloadHeading} {...appDownload} {lang} />
</Base>
