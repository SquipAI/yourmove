---
import Base from "@layouts/Base.astro";
import PageHeading from "@components/shared/PageHeading.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import TestimonialList from "@components/testimonials/TestimonialList.astro";
import PressQuotesRow from "@components/shared/PressQuotesRow.astro";
import AppDownloadSection from "@components/shared/AppDownloadSection.astro";
import {
  getReviewsPage,
  getAllTestimonials,
  getHome,
  getPress,
  getAppDownload,
} from "@lib/queries";
import { reviewsPageSchema } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { getAllLocalePaths, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";

export function getStaticPaths() {
  return getAllLocalePaths();
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const page = await getReviewsPage(lang);
if (!page) throw new Error(`Reviews page not found (${lang})`);
const [testimonials, home, press, appDownload] = await Promise.all([
  getAllTestimonials(lang),
  getHome(lang),
  getPress(lang),
  getAppDownload(),
]);
const pressQuotes = press.filter((p) => p.quote);

const localePath = localePathFor(lang);
const pageUrl = String(Astro.url);
const breadcrumbs = [
  { name: home.navLabel, url: `${Astro.url.origin}${localePath("")}` },
  { name: page.title.replace(/\*/g, ""), url: pageUrl },
];
const ogImage = ogImageHref(Astro.url.origin, lang, "reviews");
const schema = reviewsPageSchema(
  page,
  testimonials,
  pressQuotes,
  pageUrl,
  lang,
  breadcrumbs,
  ogImage,
);
---

<Base
  title={page.metaTitle}
  description={page.metaDescription}
  {lang}
  {ogImage}
>
  <SchemaOrg slot="head" {schema} />

  <section class="section">
    <PageHeading title={page.title} subtitle={page.description} />
  </section>

  <section class="section pt-0">
    <TestimonialList
      {testimonials}
      {lang}
      variant="column"
      level={2}
      interstitialAt={6}
    >
      <PressQuotesRow
        slot="interstitial"
        {pressQuotes}
        {lang}
        level={2}
        class="py-section-xs"
      />
    </TestimonialList>
  </section>

  <AppDownloadSection heading={page.downloadHeading} {...appDownload} {lang} />
</Base>
