---
import Base from "@layouts/Base.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import HomeHero from "@components/home/HomeHero.astro";
import ToolsShowcaseSection from "@components/home/ToolsShowcaseSection.astro";
import FaqSection from "@components/shared/FaqSection.astro";
import ListingSection from "@components/shared/ListingSection.astro";
import TestimonialsSection from "@components/testimonials/TestimonialsSection.astro";
import CtaSection from "@components/shared/CtaSection.astro";
import FeaturedList from "@components/blog/ui/FeaturedList.astro";
import {
  getHome,
  getSiteStats,
  getAllTestimonials,
  getFeaturedPosts,
  getPress,
  getToolCount,
  getCompatibilityApps,
  BLOG_FEATURED_COUNT,
} from "@lib/queries";
import { t } from "@i18n/ui";
import { homeSchema } from "@lib/schema";
import { ogImageHref } from "@lib/og/route";
import { canonicalUrl } from "@lib/canonicalUrl";
import { getAllLocalePaths, localePathFor } from "@i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";

export function getStaticPaths() {
  return getAllLocalePaths();
}

const lang = (Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const [
  home,
  siteStats,
  allTestimonials,
  toolCount,
  featuredPosts,
  press,
  appLogos,
] = await Promise.all([
  getHome(lang),
  getSiteStats(),
  getAllTestimonials(lang),
  getToolCount(lang),
  getFeaturedPosts(BLOG_FEATURED_COUNT, lang),
  getPress(lang),
  getCompatibilityApps(),
]);
if (!home) throw new Error(`Home document not found (${lang})`);
const pressLogos = press.filter((p) => !p.hidden);
const pressQuotes = press.filter((p) => p.quote);
const eyebrow = home.statsEyebrow
  .replace("{count}", siteStats.userCount)
  .replace("{rating}", siteStats.userRating);
const localePath = localePathFor(lang);
const pageUrl = canonicalUrl(Astro.url);
const ogImage = ogImageHref(Astro.url.origin, lang, "home");
const schema = homeSchema(
  allTestimonials,
  pressQuotes,
  home.faq.items,
  pageUrl,
  lang,
  home.metaTitle,
  home.metaDescription,
  ogImage,
);
---

<Base
  title={home.metaTitle}
  description={home.metaDescription}
  {lang}
  ogImage={ogImage}
>
  <SchemaOrg slot="head" {schema} />

  <HomeHero
    title={home.title}
    subtitle={home.description}
    {eyebrow}
    cta={home.cta}
    chatCards={home.chatCards}
    appStoreUrl={home.appStoreUrl}
    playStoreUrl={home.playStoreUrl}
    press={pressLogos}
    {lang}
  />

  <ToolsShowcaseSection
    tools={home.tools}
    {toolCount}
    appLogos={appLogos}
    appLogosLabel={t(lang, "tools.compatibleWith")}
    {lang}
    class="bg-dark text-white [&_h2+p]:text-white sm:[&_h2+p]:text-balance"
  />

  <TestimonialsSection
    testimonials={home.reviews.items}
    heading={home.reviews.heading}
    eyebrow={home.reviews.eyebrow}
    subtitle={home.reviews.subtitle}
    {pressQuotes}
    {lang}
  />

  {
    featuredPosts.length > 0 && (
      <ListingSection title={home.blogHeading} seeAllHref={localePath("blog")} {lang}>
        <FeaturedList posts={featuredPosts} {lang} />
      </ListingSection>
    )
  }

  <FaqSection
    items={home.faq.items}
    heading={home.faq.heading}
    eyebrow={home.faq.eyebrow}
    subtitle={home.faq.subtitle}
    align="center"
    {lang}
  />

  <CtaSection
    heading={home.downloadHeading}
    {...siteStats}
    appStoreUrl={home.appStoreUrl}
    playStoreUrl={home.playStoreUrl}
    {lang}
  />
</Base>
