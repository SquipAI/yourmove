---
import PostPage from "@components/blog/pages/PostPage.astro";
import {
  getPostBySlug,
  getRelatedPosts,
  getAllPostSlugs,
  getHome,
  getBlogPage,
} from "@lib/queries";

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const [post, home, blog] = await Promise.all([
  getPostBySlug(slug!),
  getHome(),
  getBlogPage(),
]);
const related = await getRelatedPosts(post!._id, post!.tagIds);
---

<PostPage
  post={post!}
  {related}
  homeTitle={home.title}
  blogTitle={blog.title}
/>
