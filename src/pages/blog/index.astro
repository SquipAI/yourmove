---
import BlogPage from "@components/blog/pages/BlogPage.astro";
import {
  getBlogPage,
  getLatestPosts,
  getFeaturedPosts,
  getTagsWithPostPreview,
  getAllTagsWithCount,
  BLOG_LATEST_COUNT,
  BLOG_FEATURED_COUNT,
} from "@lib/queries";

const [page, latest, featured, tagSections, allTags] = await Promise.all([
  getBlogPage(),
  getLatestPosts(BLOG_LATEST_COUNT),
  getFeaturedPosts(BLOG_FEATURED_COUNT),
  getTagsWithPostPreview(),
  getAllTagsWithCount(),
]);
---

<BlogPage {page} {latest} {featured} {tagSections} {allTags} />
