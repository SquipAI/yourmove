---
import BlogPage from "@components/blog/pages/BlogPage.astro";
import {
  getBlogPage,
  getLatestPosts,
  getFeaturedPosts,
  getTagsWithPostPreview,
  getAllTagsWithCount,
  getPostCount,
  BLOG_LATEST_COUNT,
  BLOG_FEATURED_COUNT,
} from "@lib/queries";

const [page, latest, featured, tagSections, allTags, postCount] =
  await Promise.all([
    getBlogPage(),
    getLatestPosts(BLOG_LATEST_COUNT),
    getFeaturedPosts(BLOG_FEATURED_COUNT),
    getTagsWithPostPreview(),
    getAllTagsWithCount(),
    getPostCount(),
  ]);
---

<BlogPage {page} {latest} {featured} {tagSections} {allTags} {postCount} />
