---
import TagPostsPage from "@components/blog/pages/TagPostsPage.astro";
import { getAllTagsWithCount, getTagBySlug, getTagPosts } from "@lib/queries";

export async function getStaticPaths() {
  const tags = await getAllTagsWithCount();
  return tags.map((tag) => ({ params: { tag: tag.slug } }));
}

const { tag: slug } = Astro.params;
const [tag, posts, allTags] = await Promise.all([
  getTagBySlug(slug),
  getTagPosts(slug),
  getAllTagsWithCount(),
]);
const otherTags = allTags.filter((t) => t.slug !== slug);
---

<TagPostsPage {posts} {tag} {otherTags} />
