---
import Base from "@layouts/Base.astro";
---

<Base title="Page Not Found | YourMove.ai" description="The page you're looking for doesn't exist.">
  <meta name="robots" content="noindex" slot="head" />
  <section class="mx-auto max-w-3xl px-4 py-32 text-center">
    <p class="text-6xl font-bold text-gray-200 mb-4">404</p>
    <h1 class="text-3xl font-bold tracking-tight mb-4">Page Not Found</h1>
    <p class="text-gray-500 mb-10">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="inline-block px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors">
      Go Home
    </a>
  </section>
</Base>
