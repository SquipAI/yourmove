---
import Base from "@layouts/Base.astro";
import PageHeading from "@components/ui/PageHeading.astro";
---

<Base
  title="Page Not Found | YourMove.ai"
  description="The page you're looking for doesn't exist."
>
  <meta name="robots" content="noindex" slot="head" />
  <section
    class="section lg:pt-section-sm flex flex-col items-center text-center"
  >
    <PageHeading
      class="*:mx-auto"
      title="Page Not Found"
      subtitle="The page you're looking for doesn't exist or has been moved."
    />
    <p class="-order-1 text-title-big font-bold text-subtle mb-4">404</p>
    <a href="/" class="btn btn-solid mt-6">Go Home</a>
  </section>
</Base>
