---
import Base from "@layouts/Base.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { HomeData } from "@lib/types";

interface Props {
  home: HomeData;
  lang?: Locale;
}

const { home, lang = DEFAULT_LOCALE } = Astro.props;

---

<Base title={home.metaTitle} description={home.metaDescription} {lang}>
  <section class="mx-auto max-w-6xl px-4 py-20 text-center">
    <h1 class="text-4xl font-bold tracking-tight">YourMove AI</h1>
  </section>
</Base>
