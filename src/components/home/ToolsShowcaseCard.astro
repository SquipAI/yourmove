---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "@i18n/config";
import type { ShowcaseCard, ShowcaseDemo } from "@lib/types";
import Btn from "@components/shared/Btn.astro";
import BeforeAfterDemo from "@components/home/showcase/BeforeAfterDemo.astro";
import BioDemo from "@components/home/showcase/BioDemo.astro";
import ChatDemo from "@components/home/showcase/ChatDemo.astro";
import OpenersDemo from "@components/home/showcase/OpenersDemo.astro";
import ReviewDemo from "@components/home/showcase/ReviewDemo.astro";

interface Props {
  card: ShowcaseCard;
  lang: Locale;
}
const { card, lang } = Astro.props;

// Per-demo accent color for the card background (drives --color-brand-darker).
const BRAND: Record<ShowcaseDemo["_type"], string | undefined> = {
  chatDemo: undefined,
  openersDemo: "var(--color-yellow-700)",
  reviewDemo: "var(--color-rose-950)",
  bioDemo: "var(--color-subtle)",
  beforeAfterDemo: "var(--color-slate-800)",
};

const demo = card.demo;
const brand = demo ? BRAND[demo._type] : "var(--color-zinc-700)";
const demoClass = "min-h-0 overflow-clip rounded-lg bg-white/6 p-4";

const href = card.external ? card.href : getRelativeLocaleUrl(lang, card.href);
const linkAttrs = card.external
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};
---

<article
  class:list={[
    "showcase-card grid grid-cols-1 gap-4 bg-linear-150 from-brand-darker text-white",
  ]}
  style={brand ? `--color-brand-darker: ${brand}` : undefined}
>
  <h3 class="text-title-sm">{card.title}</h3>
  {demo?._type === "chatDemo" && <ChatDemo {demo} class={demoClass} />}
  {demo?._type === "openersDemo" && <OpenersDemo {demo} class={demoClass} />}
  {demo?._type === "reviewDemo" && <ReviewDemo {demo} class={demoClass} />}
  {demo?._type === "bioDemo" && <BioDemo {demo} class={demoClass} />}
  {demo?._type === "beforeAfterDemo" && (
    <BeforeAfterDemo {demo} {lang} class={demoClass} />
  )}
  {card.description && <p>{card.description}</p>}
  <Btn
    href={href}
    variant="inverted"
    class="mt-auto gap-2 px-4 py-2 text-dark hover:bg-brand-darker hover:border-white/18 hover:shadow-white/12 hover:shadow-md"
    {...linkAttrs}
  >
    {card.buttonText}
    <span aria-hidden="true">→</span>
  </Btn>
</article>
