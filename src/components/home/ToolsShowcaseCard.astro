---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "@i18n/config";
import type { ShowcaseCard } from "@lib/types";
import Btn from "@components/shared/Btn.astro";
import BeforeAfterDemo from "@components/home/showcase/BeforeAfterDemo.astro";
import BioDemo from "@components/home/showcase/BioDemo.astro";
import ChatDemo from "@components/home/showcase/ChatDemo.astro";
import OpenersDemo from "@components/home/showcase/OpenersDemo.astro";
import ReviewDemo from "@components/home/showcase/ReviewDemo.astro";

interface Props {
  card: ShowcaseCard;
  lang: Locale;
}
const { card, lang } = Astro.props;

const REGISTRY = {
  chatDemo: { Component: ChatDemo, brand: undefined },
  openersDemo: { Component: OpenersDemo, brand: "var(--color-yellow-700)" },
  reviewDemo: { Component: ReviewDemo, brand: "var(--color-rose-950)" },
  bioDemo: { Component: BioDemo, brand: "var(--color-subtle)" },
  beforeAfterDemo: {
    Component: BeforeAfterDemo,
    brand: "var(--color-slate-800)",
  },
} as const;

const FALLBACK = { Component: null, brand: "var(--color-zinc-700)" };

const variant = card.demo ? REGISTRY[card.demo._type] : FALLBACK;
// `as any`: TS can't link `_type` to matching Component props through the registry.
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const Demo = variant.Component as any;

const href = card.external ? card.href : getRelativeLocaleUrl(lang, card.href);
const linkAttrs = card.external
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};
---

<article
  class:list={[
    "showcase-card grid grid-cols-1 gap-4 bg-linear-150 from-brand-darker text-white",
  ]}
  style={variant.brand ? `--color-brand-darker: ${variant.brand}` : undefined}
>
  <h3 class="text-title-sm">{card.title}</h3>
  {
    Demo && (
      <Demo
        demo={card.demo}
        {lang}
        class="min-h-0 overflow-clip rounded-lg bg-white/6 p-4"
      />
    )
  }
  {card.description && <p>{card.description}</p>}
  <Btn
    href={href}
    variant="inverted"
    class="mt-auto gap-2 px-4 py-2 text-dark hover:bg-brand-darker hover:border-white/18 hover:shadow-white/12 hover:shadow-md"
    {...linkAttrs}
  >
    {card.buttonText}
    <span aria-hidden="true">→</span>
  </Btn>
</article>
