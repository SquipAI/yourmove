---
import type { ShowcaseDemo } from "@lib/types";

interface Props {
  demo: Extract<ShowcaseDemo, { _type: "chatDemo" }>;
  class?: string;
}
const { demo, class: cls } = Astro.props;
---

<div class:list={["flex flex-col gap-2", cls]}>
  <p class="chat-bubble self-start bg-white/15">
    <span class="sr-only">Match: </span>
    {demo.theirMessage}
  </p>
  <p class="chat-bubble self-end bg-white text-mist-900">
    <span class="sr-only">yourmove: </span>
    {demo.ourReply}
  </p>
</div>
