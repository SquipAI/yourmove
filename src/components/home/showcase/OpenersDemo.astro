---
import type { ShowcaseDemo } from "@lib/types";

interface Props {
  demo: Extract<ShowcaseDemo, { _type: "openersDemo" }>;
  class?: string;
}
const { demo, class: cls } = Astro.props;
---

<ul class:list={["flex flex-col gap-2", cls]}>
  {
    demo.items.map((item) => (
      <li class="flex flex-col gap-1">
        <span class="tracking-eyebrow text-xs uppercase opacity-60">
          {item.tag}
        </span>
        <p class="rounded-xl bg-white px-3 py-2.5 text-sm text-dark">{item.text}</p>
      </li>
    ))
  }
</ul>
