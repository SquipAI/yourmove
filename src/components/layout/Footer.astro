---
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { NavItem } from "@lib/links";
import LogoSvg from "@assets/svg/LogoSvg.astro";
import InstagramIcon from "@assets/svg/instagram-icon.svg";
import TikTokIcon from "@assets/svg/tiktok-icon.svg";
import EmailIcon from "@assets/svg/email-icon.svg";
import { t } from "@i18n/ui";

interface Props {
  lang: Locale;
  tagline?: string | null;
  toolsColumn: { title: string; items: NavItem[]; seeAll: NavItem };
  columns?: { title: string; items: NavItem[] }[];
  instagramUrl: string;
  tiktokUrl: string;
  supportUrl: string;
}

const {
  lang,
  tagline,
  toolsColumn,
  columns = [],
  instagramUrl,
  tiktokUrl,
  supportUrl,
} = Astro.props;
const year = new Date().getFullYear();

const allColumns = [
  {
    title: toolsColumn.title,
    items: [...toolsColumn.items, toolsColumn.seeAll],
  },
  ...columns,
];

const socialLinks = [
  {
    href: instagramUrl,
    label: t(lang, "social.instagram"),
    Icon: InstagramIcon,
  },
  { href: tiktokUrl, label: t(lang, "social.tiktok"), Icon: TikTokIcon },
  { href: supportUrl, label: t(lang, "social.email"), Icon: EmailIcon },
];
---

<footer id="footer" class="bg-dark text-white">
  <div class="flex flex-col gap-10 sm:flex-row sm:justify-between">
    <!-- Brand -->
    <div class="flex flex-col gap-3">
      <a
        href={lang === DEFAULT_LOCALE ? "/" : `/${lang}`}
        aria-label={t(lang, "header.homeLabel")}
        class="max-w-36"
      >
        <LogoSvg />
      </a>
      {tagline && <p class="text-sm">{tagline}</p>}
      <p class="text-sm opacity-90">© {year} YourMove AI</p>
      <address class="not-italic">
        <div class="flex gap-1">
          {
            socialLinks.map(({ href, label, Icon }) => (
              <a
                href={href}
                aria-label={label}
                target="_blank"
                rel="noopener noreferrer"
                class="size-[44px] -translate-x-1/5 inline-flex flex-1 items-center justify-center rounded-lg opacity-80"
              >
                <Icon class="size-4/5" aria-hidden="true" />
              </a>
            ))
          }
        </div>
      </address>
    </div>

    <!-- Nav -->
    <nav aria-label={t(lang, "footer.navLabel")} class="flex flex-col gap-8 sm:contents">
      {
        allColumns.map((col, i) => (
          <div class:list={[i === 0 && "sm:order-last"]}>
            <p class="mb-3 text-xs font-semibold tracking-widest uppercase opacity-80">
              {col.title}
            </p>
            <ul class="flex flex-col gap-2">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="block leading-loose text-sm opacity-90"
                    {...(item.external
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>
</footer>
