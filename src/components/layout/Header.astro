---
import { LOCALES, DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { NavItem } from "@lib/types";
import LogoSvg from "@assets/svg/LogoSvg.astro";
import Btn from "@components/ui/Btn.astro";
import ChevronDown from "@components/ui/ChevronDown.astro";

interface Props {
  lang?: Locale;
  alternateUrls?: Partial<Record<Locale, string>>;
  navItems?: NavItem[];
}

const {
  lang = DEFAULT_LOCALE,
  alternateUrls = {},
  navItems = [],
} = Astro.props;

function localeHref(l: Locale) {
  if (alternateUrls[l]) return alternateUrls[l]!;
  return l === DEFAULT_LOCALE ? "/" : `/${l}`;
}

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header id="header" class="bg-brand sticky top-0 z-10 text-white">
  <div class="flex items-center justify-between gap-6 py-3">
    <a
      href={lang === DEFAULT_LOCALE ? "/" : `/${lang}`}
      aria-label="YourMove AI home"
      class="logo z-11"
    >
      <LogoSvg />
    </a>

    <!-- Nav: mobile overlay + desktop inline -->
    <nav
      id="site-nav"
      aria-label="Main navigation"
      class="bg-brand pointer-events-none fixed inset-0 flex flex-col gap-8 px-6 pt-20 pb-10 opacity-0 transition-opacity data-open:pointer-events-auto data-open:opacity-100 md:pointer-events-auto md:static md:flex-1 md:flex-row md:items-center md:gap-0 md:bg-transparent md:p-0 md:opacity-100 md:transition-none"
    >
      {
        navItems.length > 0 && (
          <ul class="flex flex-col gap-2 md:flex-row md:items-center md:gap-0.5">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={
                    !item.external && isActive(item.href) ? "page" : undefined
                  }
                  {...(item.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                  class:list={[
                    "block rounded-md px-3 py-1.5 transition-colors",
                    !item.external && isActive(item.href)
                      ? "md:bg-white/20"
                      : "md:hover:bg-white/10 md:hover:text-white",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        )
      }

      <!-- Language switcher mobile -->
      <div
        class="mt-auto flex gap-4 md:hidden"
        role="list"
        aria-label="Select language"
      >
        {
          LOCALES.map((l) => (
            <a
              href={localeHref(l)}
              hreflang={l}
              role="listitem"
              aria-current={l === lang ? "page" : undefined}
              class:list={[
                "text-sm uppercase transition-opacity",
                l === lang ? "" : "opacity-50 hover:opacity-100",
              ]}
            >
              {l}
            </a>
          ))
        }
      </div>
    </nav>

    <!-- Language dropdown -->
    <div id="lang-dropdown" class="hidden md:block">
      <button
        id="lang-btn"
        popovertarget="lang-list"
        aria-label={`Language: ${lang.toUpperCase()}, open selector`}
        class="lang-btn flex cursor-pointer items-center gap-1.5 rounded-md px-2 py-1.5 transition-colors hover:bg-white/10"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path
            d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
          ></path>
        </svg>
        <span class="uppercase">{lang}</span>
        <ChevronDown class="w-3" />
      </button>

      <ul
        id="lang-list"
        popover
        role="menu"
        aria-label="Select language"
        class="lang-list absolute min-w-20 origin-top-right scale-95 rounded-lg border-0 bg-white py-1.5 opacity-0 shadow-lg ring-1 ring-black/5 transition-[opacity,scale,display,overlay] transition-discrete duration-150 ease-in open:scale-100 open:opacity-100 starting:open:scale-95 starting:open:opacity-0"
      >
        {
          LOCALES.map((l) => (
            <li role="none">
              <a
                role="menuitem"
                href={localeHref(l)}
                hreflang={l}
                tabindex={l === lang ? -1 : 0}
                class:list={[
                  "block px-3 py-1.5 text-black uppercase transition-opacity",
                  l === lang ? "" : "opacity-50 hover:opacity-100",
                ]}
              >
                {l}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- CTA -->
    <Btn href="https://app.yourmove.ai" variant="ghost">Get Started</Btn>

    <!-- Burger -->
    <button
      id="burger-btn"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Open navigation"
      class="group relative z-11 flex aspect-square w-[44px] cursor-pointer items-center justify-center md:hidden"
    >
      <span
        class="relative transition-colors group-aria-expanded:bg-transparent before:-top-[6px] group-aria-expanded:before:rotate-45 after:top-[6px] group-aria-expanded:after:-rotate-45 [&,&::before,&::after]:h-[2px] [&,&::before,&::after]:w-[20px] [&,&::before,&::after]:rounded-full [&,&::before,&::after]:bg-current [&::before,&::after]:absolute [&::before,&::after]:left-0 [&::before,&::after]:transition-transform group-aria-expanded:[&::before,&::after]:top-0"
      ></span>
    </button>
  </div>
</header>

<style>
  #lang-btn {
    anchor-name: --lang-btn;
  }
  #lang-list {
    position-anchor: --lang-btn;
    inset: auto;
    top: anchor(bottom);
    right: anchor(right);
    margin-top: 0.5rem;
  }
</style>

<script>
  function initHeader() {
    const burger = document.getElementById("burger-btn") as HTMLButtonElement;
    const nav = document.getElementById("site-nav") as HTMLElement;
    if (!burger || !nav) return;

    if (window.innerWidth < 768) nav.setAttribute("inert", "");

    let menuOpen = false;

    function openMenu() {
      menuOpen = true;
      burger.setAttribute("aria-expanded", "true");
      burger.setAttribute("aria-label", "Close navigation");
      nav.removeAttribute("inert");
      nav.dataset.open = "";
      document.body.style.overflow = "hidden";
      setTimeout(
        () => (nav.querySelector("a") as HTMLElement | null)?.focus(),
        50,
      );
    }

    function closeMenu() {
      menuOpen = false;
      burger.setAttribute("aria-expanded", "false");
      burger.setAttribute("aria-label", "Open navigation");
      nav.setAttribute("inert", "");
      delete nav.dataset.open;
      document.body.style.overflow = "";
    }

    burger.addEventListener("click", () =>
      menuOpen ? closeMenu() : openMenu(),
    );
    nav.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        if (menuOpen) closeMenu();
      }),
    );

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menuOpen) {
        closeMenu();
        burger.focus();
      }
    });

    window.matchMedia("(min-width: 768px)").addEventListener("change", (e) => {
      if (e.matches) {
        nav.removeAttribute("inert");
        if (menuOpen) {
          menuOpen = false;
          burger.setAttribute("aria-expanded", "false");
          delete nav.dataset.open;
          document.body.style.overflow = "";
        }
      } else {
        if (!menuOpen) nav.setAttribute("inert", "");
      }
    });
  }

  initHeader();
</script>
