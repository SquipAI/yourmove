---
import { LOCALES, DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { NavItem } from "@lib/links";
import LogoSvg from "@assets/svg/LogoSvg.astro";
import ChevronDown from "@components/shared/ChevronDown.astro";
import NavLink from "@components/shared/NavLink.astro";

interface Props {
  lang: Locale;
  alternateUrls: Record<Locale, string>;
  tools: { title: string; items: NavItem[]; seeAll: NavItem };
  flatLinks: NavItem[];
  ctaUrl: string;
}

const {
  lang,
  alternateUrls,
  tools,
  flatLinks,
  ctaUrl,
} = Astro.props;

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header id="header" class="sticky top-0 z-10 bg-brand text-white">
  <div
    class="py-[12px] flex flex-wrap items-center justify-between gap-x-svw gap-y-4 sm:gap-x-6"
  >
    <a
      href={lang === DEFAULT_LOCALE ? "/" : `/${lang}`}
      aria-label={t(lang, "header.homeLabel")}
      class="relative z-11 pt-1.25 pb-1 [&>svg]:aspect-[5.5] [&>svg]:h-5"
    >
      <LogoSvg />
    </a>

    <nav
      id="site-nav"
      aria-label={t(lang, "header.navLabel")}
      class="fixed inset-0 px-svw pt-20 pb-[24px]
             flex flex-col gap-8
             bg-brand pointer-events-none opacity-0 transition-opacity
             data-open:pointer-events-auto data-open:opacity-100
             md:static md:p-0 md:flex-row md:gap-0
             md:bg-transparent md:opacity-100 md:pointer-events-auto"
    >
      <ul class="flex flex-col gap-1 md:flex-row md:items-center md:gap-0.5">
        <li class="md:relative">
          {/* Mobile: flat tools section */}
          <div class="md:hidden pb-1 border-b border-white/20">
            <p class="uppercase mb-2">{tools.title}</p>
            <ul class="flex flex-col gap-1 -translate-x-3">
              {
                tools.items.map((item) => (
                  <li>
                    <NavLink href={item.href} active={isActive(item.href)}>
                      {item.label}
                    </NavLink>
                  </li>
                ))
              }
              <li>
                <NavLink
                  href={tools.seeAll.href}
                  active={isActive(tools.seeAll.href)}
                >
                  {tools.seeAll.label}
                </NavLink>
              </li>
            </ul>
          </div>

          {/* Desktop dropdown */}
          <details class="hidden md:block">
            <summary class="nav-item gap-1">
              <span>{tools.title}</span>
              <ChevronDown />
            </summary>
            <ul class="min-w-56">
              {
                tools.items.map((item) => (
                  <li>
                    <NavLink href={item.href} active={isActive(item.href)}>
                      {item.label}
                    </NavLink>
                  </li>
                ))
              }
              <li>
                <NavLink
                  href={tools.seeAll.href}
                  active={isActive(tools.seeAll.href)}
                >
                  {tools.seeAll.label}
                </NavLink>
              </li>
            </ul>
          </details>
        </li>

        {
          flatLinks.map((link) => (
            <li class="md:contents max-md:-translate-x-3">
              <NavLink
                href={link.href}
                active={!link.external && isActive(link.href)}
                external={link.external}
              >
                {link.label}
              </NavLink>
            </li>
          ))
        }
      </ul>

      <!-- Language switcher mobile -->
      <ul
        class="mt-auto flex md:hidden"
        aria-label={t(lang, "header.langSelectLabel")}
      >
        {
          LOCALES.map((l) => (
            <li>
              <a
                href={alternateUrls[l]}
                hreflang={l}
                aria-current={l === lang ? "page" : undefined}
                class:list={[
                  `inline-flex items-center justify-center
                   min-h-[44px] min-w-[44px]
                   text-sm uppercase transition-opacity`,
                  l === lang ? "" : "opacity-50 hover:opacity-100",
                ]}
              >
                {l}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Language dropdown -->
    <details class="relative hidden md:block md:ms-auto">
      <summary
        aria-label={t(lang, "header.langButton").replace(
          "{lang}",
          lang.toUpperCase(),
        )}
        class="gap-[5px] rounded-md px-2 py-1 transition-colors hover:bg-white/12"
      >
        <svg
          class="size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path
            d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
          ></path>
        </svg>
        <span class="uppercase">{lang}</span>
        <ChevronDown />
      </summary>

      <ul class="min-w-20">
        {
          LOCALES.map((l) => (
            <li>
              <a
                href={alternateUrls[l]}
                hreflang={l}
                tabindex={l === lang ? -1 : 0}
                class:list={[
                  "nav-item uppercase transition-opacity",
                  l === lang ? "" : "opacity-50 hover:opacity-100",
                ]}
              >
                {l}
              </a>
            </li>
          ))
        }
      </ul>
    </details>

    <!-- CTA -->
    <a
      href={ctaUrl}
      class="nav-item bg-white text-brand whitespace-nowrap
             max-md:ms-auto max-md:translate-x-svw
             hover:bg-brand hover:text-white"
    >
      {t(lang, "header.cta")}
    </a>

    <!-- Burger -->
    <button
      id="burger-btn"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label={t(lang, "header.openNav")}
      data-label-open={t(lang, "header.openNav")}
      data-label-close={t(lang, "header.closeNav")}
      class="relative z-11 flex size-[44px] translate-x-svw
             cursor-pointer items-center justify-center
             md:hidden"
    >
      <span></span>
    </button>
  </div>
</header>

<script>
  function initHeader() {
    const burger = document.getElementById("burger-btn") as HTMLButtonElement;
    const nav = document.getElementById("site-nav") as HTMLElement;
    if (!burger || !nav) return;

    if (window.innerWidth < 768) nav.setAttribute("inert", "");

    let menuOpen = false;

    const labelOpen = burger.dataset.labelOpen ?? "";
    const labelClose = burger.dataset.labelClose ?? "";

    function openMenu() {
      menuOpen = true;
      burger.setAttribute("aria-expanded", "true");
      burger.setAttribute("aria-label", labelClose);
      nav.removeAttribute("inert");
      nav.dataset.open = "";
      document.body.style.overflow = "hidden";
      setTimeout(
        () => (nav.querySelector("a") as HTMLElement | null)?.focus(),
        50,
      );
    }

    function closeMenu() {
      menuOpen = false;
      burger.setAttribute("aria-expanded", "false");
      burger.setAttribute("aria-label", labelOpen);
      nav.setAttribute("inert", "");
      delete nav.dataset.open;
      document.body.style.overflow = "";
    }

    burger.addEventListener("click", () =>
      menuOpen ? closeMenu() : openMenu(),
    );
    nav.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        if (menuOpen) closeMenu();
      }),
    );

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menuOpen) {
        closeMenu();
        burger.focus();
      }
    });

    window.matchMedia("(min-width: 768px)").addEventListener("change", (e) => {
      if (e.matches) {
        nav.removeAttribute("inert");
        if (menuOpen) {
          menuOpen = false;
          burger.setAttribute("aria-expanded", "false");
          delete nav.dataset.open;
          document.body.style.overflow = "";
        }
      } else {
        if (!menuOpen) nav.setAttribute("inert", "");
      }
    });

    // Close dropdowns on outside click / Esc.
    const dropdowns =
      document.querySelectorAll<HTMLDetailsElement>("#header details");
    document.addEventListener("click", (e) => {
      dropdowns.forEach((d) => {
        if (d.open && !d.contains(e.target as Node)) d.open = false;
      });
    });
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      dropdowns.forEach((d) => {
        if (d.open) {
          d.open = false;
          (d.querySelector("summary") as HTMLElement | null)?.focus();
        }
      });
    });
  }

  initHeader();
</script>
