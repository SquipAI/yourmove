---
import { LOCALES, DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { NavItem } from "@lib/links";
import LogoSvg from "@assets/svg/LogoSvg.astro";
import Btn from "@components/shared/Btn.astro";
import ChevronDown from "@components/shared/ChevronDown.astro";

interface Props {
  lang?: Locale;
  alternateUrls: Record<Locale, string>;
  tools: { title: string; items: NavItem[]; seeAll: NavItem };
  flatLinks: NavItem[];
}

const {
  lang = DEFAULT_LOCALE,
  alternateUrls,
  tools,
  flatLinks,
} = Astro.props;

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header id="header" class="bg-brand sticky top-0 z-10 text-white">
  <div class="flex items-center justify-between gap-6 py-3">
    <a
      href={lang === DEFAULT_LOCALE ? "/" : `/${lang}`}
      aria-label="YourMove AI home"
      class="logo z-11"
    >
      <LogoSvg />
    </a>

    <nav
      id="site-nav"
      aria-label="Main navigation"
      class="bg-brand pointer-events-none fixed inset-0 flex flex-col gap-8 px-6 pt-20 pb-10 opacity-0 transition-opacity data-open:pointer-events-auto data-open:opacity-100 md:pointer-events-auto md:static md:flex-1 md:flex-row md:items-center md:gap-0 md:bg-transparent md:p-0 md:opacity-100 md:transition-none"
    >
      <ul
        class="flex flex-col gap-1 md:flex-row md:items-center md:gap-0.5"
      >
        <li class="md:relative">
          {/* Desktop dropdown */}
          <details class="tools-dropdown group hidden md:block">
            <summary
              class="flex cursor-pointer items-center gap-1 rounded-md px-3 py-1.5 transition-colors hover:bg-white/10 group-open:bg-white/10"
              aria-haspopup="menu"
            >
              <span>{tools.title}</span>
              <ChevronDown class="w-3 transition-transform group-open:rotate-180" />
            </summary>
            <ul
              class="absolute top-full left-0 mt-1 min-w-56 rounded-lg bg-white py-2 text-black shadow-lg ring-1 ring-black/5"
              role="menu"
            >
              {
                tools.items.map((item) => (
                  <li role="none">
                    <a
                      role="menuitem"
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                      class="block px-4 py-1.5 hover:bg-black/5"
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
              <li role="none" class="mt-1 border-t border-black/10 pt-1">
                <a
                  role="menuitem"
                  href={tools.seeAll.href}
                  aria-current={isActive(tools.seeAll.href) ? "page" : undefined}
                  class="block px-4 py-1.5 font-medium hover:bg-black/5"
                >
                  {tools.seeAll.label}
                </a>
              </li>
            </ul>
          </details>

          {/* Mobile: flat tools section */}
          <div class="md:hidden">
            <p class="text-xs uppercase opacity-70">{tools.title}</p>
            <ul class="mt-2 flex flex-col gap-1">
              {
                tools.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                      class="block rounded-md px-3 py-1.5"
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
              <li>
                <a
                  href={tools.seeAll.href}
                  aria-current={isActive(tools.seeAll.href) ? "page" : undefined}
                  class="block rounded-md px-3 py-1.5 font-medium"
                >
                  {tools.seeAll.label}
                </a>
              </li>
            </ul>
          </div>
        </li>

        {
          flatLinks.map((link) => (
            <li class="md:contents">
              <a
                href={link.href}
                aria-current={
                  !link.external && isActive(link.href) ? "page" : undefined
                }
                {...(link.external
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
                class:list={[
                  "block rounded-md px-3 py-1.5 transition-colors mt-1 md:mt-0",
                  !link.external && isActive(link.href)
                    ? "md:bg-white/20"
                    : "md:hover:bg-white/10",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Language switcher mobile -->
      <div
        class="mt-auto flex gap-4 md:hidden"
        role="list"
        aria-label="Select language"
      >
        {
          LOCALES.map((l) => (
            <a
              href={alternateUrls[l]}
              hreflang={l}
              role="listitem"
              aria-current={l === lang ? "page" : undefined}
              class:list={[
                "text-sm uppercase transition-opacity",
                l === lang ? "" : "opacity-50 hover:opacity-100",
              ]}
            >
              {l}
            </a>
          ))
        }
      </div>
    </nav>

    <!-- Language dropdown -->
    <div id="lang-dropdown" class="hidden md:block">
      <button
        id="lang-btn"
        popovertarget="lang-list"
        aria-label={`Language: ${lang.toUpperCase()}, open selector`}
        class="lang-btn flex cursor-pointer items-center gap-1.5 rounded-md px-2 py-1.5 transition-colors hover:bg-white/10"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path
            d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
          ></path>
        </svg>
        <span class="uppercase">{lang}</span>
        <ChevronDown class="w-3" />
      </button>

      <ul
        id="lang-list"
        popover
        role="menu"
        aria-label="Select language"
        class="lang-list absolute min-w-20 origin-top-right scale-95 rounded-lg border-0 bg-white py-1.5 opacity-0 shadow-lg ring-1 ring-black/5 transition-[opacity,scale,display,overlay] transition-discrete duration-150 ease-in open:scale-100 open:opacity-100 starting:open:scale-95 starting:open:opacity-0"
      >
        {
          LOCALES.map((l) => (
            <li role="none">
              <a
                role="menuitem"
                href={alternateUrls[l]}
                hreflang={l}
                tabindex={l === lang ? -1 : 0}
                class:list={[
                  "block px-3 py-1.5 text-black uppercase transition-opacity",
                  l === lang ? "" : "opacity-50 hover:opacity-100",
                ]}
              >
                {l}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- CTA -->
    <Btn href="https://app.yourmove.ai" variant="ghost">Get Started</Btn>

    <!-- Burger -->
    <button
      id="burger-btn"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Open navigation"
      class="group relative z-11 flex aspect-square w-[44px] cursor-pointer items-center justify-center md:hidden"
    >
      <span
        class="relative transition-colors group-aria-expanded:bg-transparent before:-top-[6px] group-aria-expanded:before:rotate-45 after:top-[6px] group-aria-expanded:after:-rotate-45 [&,&::before,&::after]:h-[2px] [&,&::before,&::after]:w-[20px] [&,&::before,&::after]:rounded-full [&,&::before,&::after]:bg-current [&::before,&::after]:absolute [&::before,&::after]:left-0 [&::before,&::after]:transition-transform group-aria-expanded:[&::before,&::after]:top-0"
      ></span>
    </button>
  </div>
</header>

<script>
  function initHeader() {
    const burger = document.getElementById("burger-btn") as HTMLButtonElement;
    const nav = document.getElementById("site-nav") as HTMLElement;
    if (!burger || !nav) return;

    if (window.innerWidth < 768) nav.setAttribute("inert", "");

    let menuOpen = false;

    function openMenu() {
      menuOpen = true;
      burger.setAttribute("aria-expanded", "true");
      burger.setAttribute("aria-label", "Close navigation");
      nav.removeAttribute("inert");
      nav.dataset.open = "";
      document.body.style.overflow = "hidden";
      setTimeout(
        () => (nav.querySelector("a") as HTMLElement | null)?.focus(),
        50,
      );
    }

    function closeMenu() {
      menuOpen = false;
      burger.setAttribute("aria-expanded", "false");
      burger.setAttribute("aria-label", "Open navigation");
      nav.setAttribute("inert", "");
      delete nav.dataset.open;
      document.body.style.overflow = "";
    }

    burger.addEventListener("click", () =>
      menuOpen ? closeMenu() : openMenu(),
    );
    nav.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        if (menuOpen) closeMenu();
      }),
    );

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menuOpen) {
        closeMenu();
        burger.focus();
      }
    });

    window.matchMedia("(min-width: 768px)").addEventListener("change", (e) => {
      if (e.matches) {
        nav.removeAttribute("inert");
        if (menuOpen) {
          menuOpen = false;
          burger.setAttribute("aria-expanded", "false");
          delete nav.dataset.open;
          document.body.style.overflow = "";
        }
      } else {
        if (!menuOpen) nav.setAttribute("inert", "");
      }
    });

    // Close tools dropdown on outside click / Esc.
    const dropdown = document.querySelector(
      ".tools-dropdown",
    ) as HTMLDetailsElement | null;
    if (dropdown) {
      document.addEventListener("click", (e) => {
        if (dropdown.open && !dropdown.contains(e.target as Node))
          dropdown.open = false;
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && dropdown.open) {
          dropdown.open = false;
          (dropdown.querySelector("summary") as HTMLElement | null)?.focus();
        }
      });
    }
  }

  initHeader();
</script>
