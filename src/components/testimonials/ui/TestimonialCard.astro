---
import { Image } from "astro:assets";
import { parseAccent } from "@lib/parseAccent";
import type { Testimonial, TestimonialSource } from "@lib/types";

interface Props {
  testimonial: Testimonial;
  level?: 2 | 3;
  class?: string;
}

const { testimonial, level = 3, class: cls } = Astro.props;
const Tag = `h${level}` as "h2" | "h3";

const bodyParts = parseAccent(testimonial.body);

// Strip "u/" prefix for initial letter.
const cleanName = testimonial.authorName.replace(/^u\//, "");
const initial = cleanName.charAt(0).toUpperCase() || "?";

const sourceLabel: Record<TestimonialSource, string> = {
  web: "Web",
  reddit: "Reddit",
  appStore: "App Store",
  productHunt: "Product Hunt",
};

const sourceUrl =
  testimonial.source !== "web" ? testimonial.sourceUrl : null;
---

<article class:list={["card card-body break-inside-avoid", cls]}>
  <header class="flex items-start gap-3">
    {
      testimonial.avatar?.url ? (
        <Image
          src={testimonial.avatar.url}
          alt=""
          width={48}
          height={48}
          loading="lazy"
          class="size-12 shrink-0 rounded-full object-cover"
        />
      ) : (
        <div
          class="bg-subtle-lighter text-subtle flex size-12 shrink-0 items-center justify-center rounded-full font-semibold"
          aria-hidden="true"
        >
          {initial}
        </div>
      )
    }

    <Tag class="text-base font-semibold leading-tight mt-2 mr-auto">
      {testimonial.authorName}
    </Tag>

    {
      sourceUrl && (
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View on ${sourceLabel[testimonial.source]}`}
          title={`View on ${sourceLabel[testimonial.source]}`}
          class="text-subtle hover:text-brand shrink-0 transition-colors"
        >
          {testimonial.source === "reddit" && (
            <svg
              viewBox="0 0 24 24"
              class="size-5"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M22 12a2.5 2.5 0 0 0-4.24-1.79 11.4 11.4 0 0 0-5.92-1.88l1.01-4.74 3.3.7a1.8 1.8 0 1 0 .19-.93l-3.68-.78a.47.47 0 0 0-.56.36L10.96 8.3a11.43 11.43 0 0 0-6.01 1.88A2.5 2.5 0 0 0 2 12c0 .98.57 1.83 1.4 2.24a4.5 4.5 0 0 0-.07.78c0 3.96 4.6 7.16 10.27 7.16s10.27-3.2 10.27-7.16c0-.27-.02-.53-.06-.79A2.5 2.5 0 0 0 22 12zM7 13.5a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0zm9.5 4.46c-1.16.85-2.74 1.29-4.5 1.29s-3.34-.44-4.5-1.29a.47.47 0 1 1 .56-.76c.97.71 2.34 1.1 3.94 1.1s2.97-.39 3.94-1.1a.47.47 0 1 1 .56.76zM16 15a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z" />
            </svg>
          )}
          {testimonial.source === "appStore" && (
            <svg
              viewBox="0 0 24 24"
              class="size-5"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M17.05 12.04c-.03-2.65 2.17-3.93 2.27-4-1.24-1.81-3.17-2.06-3.85-2.09-1.64-.17-3.2.97-4.03.97-.85 0-2.12-.95-3.49-.92-1.79.03-3.45 1.04-4.37 2.64-1.86 3.23-.48 8.01 1.34 10.63.89 1.28 1.95 2.72 3.32 2.67 1.34-.05 1.84-.86 3.46-.86 1.6 0 2.07.86 3.48.83 1.44-.02 2.35-1.3 3.23-2.59 1.02-1.49 1.44-2.94 1.46-3.01-.03-.01-2.8-1.08-2.82-4.27zM14.5 4.27c.73-.89 1.22-2.12 1.09-3.34-1.05.04-2.33.7-3.08 1.58-.67.78-1.26 2.04-1.1 3.23 1.18.09 2.36-.6 3.09-1.47z" />
            </svg>
          )}
          {testimonial.source === "productHunt" && (
            <svg
              viewBox="0 0 24 24"
              class="size-5"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.34 11H10v3H8V8h5.34a2.5 2.5 0 0 1 0 5zm0-3H10v1h3.34a.5.5 0 0 0 0-1z" />
            </svg>
          )}
        </a>
      )
    }
  </header>

  <p class="text-base whitespace-pre-line">
    {
      bodyParts.map((p) =>
        p.accent ? <span class="accent">{p.text}</span> : p.text,
      )
    }
  </p>

  {
    testimonial.rating != null && (
      <div
        class="text-brand mt-auto text-lg leading-none tracking-widest"
        aria-label={`${testimonial.rating} out of 5 stars`}
      >
        {"★".repeat(testimonial.rating)}
        <span class="text-subtle/30">{"★".repeat(5 - testimonial.rating)}</span>
      </div>
    )
  }
</article>
