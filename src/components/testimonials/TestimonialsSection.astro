---
import type { Locale } from "@i18n/config";
import type { Press, Testimonial } from "@lib/types";
import SectionHeading from "@components/shared/SectionHeading.astro";
import TestimonialList from "@components/testimonials/TestimonialList.astro";
import PressQuotesRow from "@components/shared/PressQuotesRow.astro";
import LogoRow from "@components/shared/LogoRow.astro";
import { t } from "@i18n/ui";

interface Props {
  testimonials: Testimonial[];
  heading: string;
  eyebrow?: string | null;
  subtitle?: string | null;
  pressQuotes?: Press[];
  /** "as seen on" wordmark strip shown under the list. Empty = hidden. */
  pressLogos?: Press[];
  lang: Locale;
}

const {
  testimonials,
  heading,
  eyebrow,
  subtitle,
  pressQuotes = [],
  pressLogos = [],
  lang,
} = Astro.props;
---

<section data-section="testimonials" class="section">
  <div>
    <SectionHeading title={heading} {eyebrow} {subtitle} />
    <TestimonialList {testimonials} {lang} class="mb-section-xs" />
    <PressQuotesRow {pressQuotes} {lang} />
    <LogoRow
      logos={pressLogos}
      label={t(lang, "home.asSeenOn")}
      level={3}
      kind="press"
    />
  </div>
</section>
