---
import type { Locale } from "@i18n/config";
import type { Press, Testimonial } from "@lib/types";
import SectionHeading from "@components/shared/SectionHeading.astro";
import TestimonialList from "@components/testimonials/TestimonialList.astro";
import PressQuotesRow from "@components/shared/PressQuotesRow.astro";

interface Props {
  testimonials: Testimonial[];
  heading: string;
  eyebrow?: string | null;
  subtitle?: string | null;
  /** Heading level for the section title. Default 2. */
  level?: 2 | 3;
  pressQuotes?: Press[];
  lang: Locale;
}

const {
  testimonials,
  heading,
  eyebrow,
  subtitle,
  level = 2,
  pressQuotes = [],
  lang,
} = Astro.props;
---

<section data-section="testimonials" class="section">
  <div>
    <SectionHeading title={heading} {eyebrow} {subtitle} {level} />
    <TestimonialList {testimonials} {lang} class="mb-section-sm" />
    <PressQuotesRow {pressQuotes} {lang} />
  </div>
</section>
