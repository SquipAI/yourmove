---
import { getRelativeLocaleUrl } from "astro:i18n";
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { Testimonial } from "@lib/types";
import SectionHeading from "@components/shared/SectionHeading.astro";
import TestimonialList from "@components/testimonials/TestimonialList.astro";

interface Props {
  testimonials: Testimonial[];
  heading: string;
  eyebrow?: string | null;
  subtitle?: string | null;
  /** Heading level for the section title. Default 2. */
  level?: 2 | 3;
  lang?: Locale;
  class?: string;
}

const {
  testimonials,
  heading,
  eyebrow,
  subtitle,
  level = 2,
  lang = DEFAULT_LOCALE,
  class: cls,
} = Astro.props;

const seeAllHref = getRelativeLocaleUrl(lang, "reviews");
---

<div class:list={["flex flex-col", cls]}>
  <SectionHeading title={heading} {eyebrow} {subtitle} {level} />
  <TestimonialList {testimonials} variant="snap" level={3} />
  <a
    href={seeAllHref}
    class="text-brand mt-section-xs inline-block font-medium hover:underline"
  >
    {t(lang, "reviews.seeAll")} →
  </a>
</div>
