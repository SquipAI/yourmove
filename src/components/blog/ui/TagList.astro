---
import { getRelativeLocaleUrl } from "astro:i18n";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { TagWithCount } from "@lib/types";

interface Props {
  tags: TagWithCount[];
  lang?: Locale;
  class?: string;
}

const { tags, lang = DEFAULT_LOCALE, class: cls } = Astro.props;

const pill =
  "inline-block rounded-full border bg-white px-4 py-1.5 text-sm transition-colors";
---

<ul class:list={["flex flex-wrap gap-2", cls]}>
  {
    tags.map((tag) => (
      <li>
        <a
          href={getRelativeLocaleUrl(lang, `blog/topics/${tag.slug}`)}
          class:list={[
            pill,
            "border-subtle-lighter text-subtle hover:border-brand hover:text-brand",
          ]}
        >
          {tag.title}
        </a>
      </li>
    ))
  }
  <li>
    <a
      href={getRelativeLocaleUrl(lang, "blog/topics")}
      class:list={[
        pill,
        "border-brand font-medium text-brand hover:bg-brand hover:text-white",
      ]}
    >
      {t(lang, "blog.allTopics")} →
    </a>
  </li>
</ul>