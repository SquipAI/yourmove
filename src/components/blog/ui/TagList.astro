---
import { getRelativeLocaleUrl } from "astro:i18n";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { TagWithCount } from "@lib/types";
import Pill from "@components/ui/Pill.astro";

interface Props {
  tags: TagWithCount[];
  lang?: Locale;
  class?: string;
}

const { tags, lang = DEFAULT_LOCALE, class: cls } = Astro.props;
---

<ul class:list={["flex flex-wrap gap-2", cls]}>
  {
    tags.map((tag) => (
      <li>
        <Pill
          href={getRelativeLocaleUrl(lang, `blog/topics/${tag.slug}`)}
          label={tag.title}
        />
      </li>
    ))
  }
  <li>
    <Pill
      href={getRelativeLocaleUrl(lang, "blog/topics")}
      label={`${t(lang, "blog.allTopics")} →`}
      variant="brand"
    />
  </li>
</ul>
