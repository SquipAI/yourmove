---
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { PostCard } from "@lib/types";
import Eyebrow from "@components/ui/Eyebrow.astro";
import CardHeading from "./CardHeading.astro";

interface Props {
  post: PostCard;
  lang?: Locale;
  level?: 2 | 3 | 4;
  imageMode?: "top" | "right" | "none";
  noDescription?: boolean;
  meta?: "readingTime" | "date" | "none";
  /** Eager-load the image with fetchpriority=high. Use for above-the-fold cards. */
  priority?: boolean;
  size?: "sm" | "md" | "lg";
  headingClass?: string;
}

const {
  post,
  lang = DEFAULT_LOCALE,
  level = 2,
  imageMode = "top",
  noDescription = false,
  meta = "readingTime",
  priority = false,
  size = "md",
  headingClass,
} = Astro.props;

const href = getRelativeLocaleUrl(lang, `blog/${post.slug}`);
const hasImageTop = imageMode === "top" && !!post.mainImage?.url;
const hasImageRight = imageMode === "right" && !!post.mainImage?.url;

const metaText =
  meta === "readingTime" && post.readingTime != null
    ? `${post.readingTime} ${t(lang, "blog.minRead")}`
    : meta === "date" && post.createdAt
      ? new Intl.DateTimeFormat(lang, {
          year: "numeric",
          month: "long",
          day: "numeric",
        }).format(new Date(post.createdAt))
      : null;
---

<article class="card group">
  <div
    class:list={[
      "flex flex-1 flex-col gap-3 p-svw md:p-6",
      hasImageRight && "lg:pr-32",
    ]}
  >
    <CardHeading
      title={post.title}
      description={noDescription ? null : post.summary}
      {href}
      {level}
      {size}
      class={headingClass}
    />

    {
      post.tags && post.tags.length > 0 && (
        <ul class="-order-1 flex flex-wrap gap-1">
          {post.tags.map((tag) => (
            <li class="text-xs font-medium px-2 py-0.5 rounded-full bg-subtle-lighter text-subtle">
              {tag.title}
            </li>
          ))}
        </ul>
      )
    }

    {metaText && <Eyebrow class="mt-auto">{metaText}</Eyebrow>}
  </div>

  {
    hasImageTop && (
      <div class="-order-1 aspect-video overflow-hidden bg-subtle-lighter">
        <Image
          src={post.mainImage!.url}
          alt={post.mainImage!.alt ?? post.title}
          width={400}
          height={225}
          loading={priority ? "eager" : "lazy"}
          fetchpriority={priority ? "high" : "auto"}
          sizes="(min-width: 1024px) calc(33vw - 32px), (min-width: 640px) calc(50vw - 24px), 100vw"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    )
  }

  {
    hasImageRight && (
      <div class="absolute right-0 top-0 hidden h-full aspect-square overflow-hidden rounded-e-md bg-subtle-lighter lg:block">
        <Image
          src={post.mainImage!.url}
          alt={post.mainImage!.alt ?? post.title}
          width={200}
          height={200}
          loading="lazy"
          sizes="96px"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    )
  }
</article>
