---
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { PostCard } from "@lib/types";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";

interface Props {
  post: PostCard;
  lang?: Locale;
  level?: 2 | 3;
}

const { post, lang = DEFAULT_LOCALE, level = 2 } = Astro.props;
const HeadingTag = `h${level}` as "h2" | "h3";
const href = getRelativeLocaleUrl(lang, `blog/${post.slug}`);
---

<article class="flex flex-col rounded-xl overflow-hidden border border-gray-100 bg-white hover:shadow-md transition-shadow group">
  {post.mainImage?.url && (
    <a href={href} tabindex="-1" aria-hidden="true" class="aspect-video overflow-hidden bg-gray-100 shrink-0">
      <Image
        src={post.mainImage.url}
        alt={post.mainImage.alt ?? post.title}
        width={400}
        height={225}
        loading="lazy"
        sizes="(min-width: 1024px) calc(33vw - 32px), (min-width: 640px) calc(50vw - 24px), 100vw"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </a>
  )}
  <div class="flex flex-col gap-2 p-5 flex-1">
    {post.tags && post.tags.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {post.tags.map((tag) => (
          <a
            href={getRelativeLocaleUrl(lang, `blog/tags/${tag.slug}`)}
            class="relative z-10 text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 transition-colors"
          >
            {tag.title}
          </a>
        ))}
      </div>
    )}
    <HeadingTag class="text-base font-semibold leading-snug">
      <a href={href} class="text-gray-900 hover:text-gray-600 transition-colors">
        {post.title}
      </a>
    </HeadingTag>
    <p class="text-sm text-gray-500 line-clamp-2 flex-1">{post.summary}</p>
    <div class="flex items-center justify-between mt-2">
      {post.readingTime != null && (
        <span class="text-xs text-gray-400">{post.readingTime} {t(lang, "blog.minRead")}</span>
      )}
      <a href={href} class="text-xs font-medium text-gray-900 hover:underline ml-auto">
        {t(lang, "blog.readMore")}
      </a>
    </div>
  </div>
</article>
