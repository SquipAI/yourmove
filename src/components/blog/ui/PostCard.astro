---
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { PostCard } from "@lib/types";
import { urlFor } from "@lib/sanity-image";
import Eyebrow from "@components/shared/Eyebrow.astro";
import CardHeading from "@components/blog/ui/CardHeading.astro";

interface Props {
  post: PostCard;
  lang?: Locale;
  level?: 2 | 3 | 4;
  imageMode?: "top" | "right" | "none";
  noDescription?: boolean;
  meta?: "readingTime" | "date" | "none";
  /** Eager-load the image with fetchpriority=high. Use for above-the-fold cards. */
  priority?: boolean;
  size?: "sm" | "md" | "lg";
  headingClass?: string;
}

const {
  post,
  lang = DEFAULT_LOCALE,
  level = 2,
  imageMode = "top",
  noDescription = false,
  meta = "readingTime",
  priority = false,
  size = "md",
  headingClass,
} = Astro.props;

const href = getRelativeLocaleUrl(lang, `blog/${post.slug}`);
const hasImageTop = imageMode === "top";
const hasImageRight = imageMode === "right";

const metaText =
  meta === "readingTime"
    ? `${post.readingTime} ${t(lang, "blog.minRead")}`
    : meta === "date"
      ? new Intl.DateTimeFormat(lang, {
          year: "numeric",
          month: "long",
          day: "numeric",
        }).format(new Date(post.createdAt))
      : null;
---

<article class="card group flex flex-col">
  <div class:list={["card-body flex-1", hasImageRight && "lg:pr-32"]}>
    <CardHeading
      title={post.title}
      description={noDescription ? null : post.summary}
      {href}
      {level}
      {size}
      class={headingClass}
    />

    <ul class="-order-1 flex flex-wrap gap-1">
      {
        post.tags.map((tag) => (
          <li class="bg-subtle-lighter text-subtle rounded-full px-2 py-0.5 text-xs font-medium">
            {tag.title}
          </li>
        ))
      }
    </ul>

    {metaText && <Eyebrow class="mt-auto">{metaText}</Eyebrow>}
  </div>

  {
    hasImageTop && (
      <div class="bg-subtle-lighter -order-1 aspect-video overflow-hidden">
        <Image
          src={urlFor(post.mainImage).width(400).height(225).fit("crop").url()}
          alt=""
          width={400}
          height={225}
          priority={priority}
          sizes="(min-width: 1024px) calc(33vw - 32px), (min-width: 640px) calc(50vw - 24px), 100vw"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    )
  }

  {
    hasImageRight && (
      <div class="bg-subtle-lighter absolute top-0 right-0 hidden aspect-square h-full overflow-hidden rounded-e-md lg:block">
        <Image
          src={urlFor(post.mainImage).width(200).height(200).fit("crop").url()}
          alt=""
          width={200}
          height={200}
          loading="lazy"
          sizes="96px"
          class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    )
  }
</article>
