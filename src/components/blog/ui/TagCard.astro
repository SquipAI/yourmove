---
import { getRelativeLocaleUrl } from "astro:i18n";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { TagWithCount } from "@lib/types";
import Eyebrow from "@components/shared/Eyebrow.astro";
import CardHeading from "@components/blog/ui/CardHeading.astro";

interface Props {
  tag: TagWithCount;
  lang?: Locale;
  level?: 2 | 3;
}

const { tag, lang = DEFAULT_LOCALE, level = 2 } = Astro.props;
const href = getRelativeLocaleUrl(lang, `blog/topics/${tag.slug}`);
const countLabel = `${tag.postCount} ${t(lang, tag.postCount === 1 ? "blog.article" : "blog.articles")}`;
---

<li class="card card-body justify-between">
  <CardHeading title={tag.title} description={tag.description} {href} {level} />
  <Eyebrow>{countLabel}</Eyebrow>
</li>
