---
import Base from "@layouts/Base.astro";
import PostCard from "@components/blog/ui/PostCard.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import { localePathFor } from "@i18n/utils";
import type { BlogHubData, PostCard as PostCardType, TagWithPosts } from "@lib/types";

interface Props {
  hub: BlogHubData;
  latest: PostCardType[];
  featured: PostCardType[];
  tagSections: TagWithPosts[];
  lang?: Locale;
}

const { hub, latest, featured, tagSections, lang = DEFAULT_LOCALE } = Astro.props;

const localePath = localePathFor(lang);
---

<Base title={hub.metaTitle} description={hub.metaDescription} {lang}>
  <div class="mx-auto max-w-6xl px-4 py-12">

    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight">{hub?.title}</h1>
      {hub?.intro && <p class="mt-3 text-lg text-gray-500">{hub.intro}</p>}
    </header>

    <div class="space-y-16">

      {latest.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold">{t(lang, "blog.latest")}</h2>
            <a href={localePath("blog/posts")} class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              {t(lang, "blog.seeAll")}
            </a>
          </div>
          <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {latest.map((post) => <li><PostCard {post} {lang} level={3} /></li>)}
          </ul>
        </section>
      )}

      {featured.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold">{t(lang, "blog.featured")}</h2>
            <a href={localePath("blog/posts")} class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              {t(lang, "blog.seeAll")}
            </a>
          </div>
          <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((post) => <li><PostCard {post} {lang} level={3} /></li>)}
          </ul>
        </section>
      )}

      {tagSections.map((section) => (
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold">{section.title}</h2>
            <a href={localePath(`blog/tags/${section.slug}`)} class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              {t(lang, "blog.seeAll")}
            </a>
          </div>
          <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {section.posts.map((post) => <li><PostCard {post} {lang} level={3} /></li>)}
          </ul>
        </section>
      ))}

    </div>
  </div>
</Base>
