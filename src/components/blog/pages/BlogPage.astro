---
import Base from "@layouts/Base.astro";
import FeaturedSection from "@components/blog/ui/FeaturedSection.astro";
import LatestSection from "@components/blog/ui/LatestSection.astro";
import PostCard from "@components/blog/ui/PostCard.astro";
import SeeAllLink from "@components/blog/ui/SeeAllLink.astro";
import TagList from "@components/blog/ui/TagList.astro";
import PageHeading from "@components/ui/PageHeading.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import { localePathFor } from "@i18n/utils";
import type {
  BlogPageData,
  PostCard as PostCardType,
  TagWithCount,
  TagWithPosts,
} from "@lib/types";

interface Props {
  page: BlogPageData;
  latest: PostCardType[];
  featured: PostCardType[];
  tagSections: TagWithPosts[];
  allTags: TagWithCount[];
  lang?: Locale;
}

const {
  page,
  latest,
  featured,
  tagSections,
  allTags,
  lang = DEFAULT_LOCALE,
} = Astro.props;

const localePath = localePathFor(lang);
---

<Base title={page.metaTitle} description={page.metaDescription} {lang}>
  <header class="section pb-section-sm lg:pt-section-sm">
    <PageHeading title={page.title} subtitle={page.intro} size="big" />
  </header>

  <section class="section pt-0 xl:pb-section-sm">
    <h2 class="sr-only">{t(lang, "blog.featured")}</h2>
    <FeaturedSection posts={featured} {lang} />
  </section>

  <section class="section bg-subtle-lighter xl:py-section-sm">
    <div class="grid md:grid-cols-[1fr_auto]">
      <SectionHeading title={t(lang, "blog.latest")} />
      <LatestSection posts={latest} {lang} />
      <SeeAllLink
        href={localePath("blog/posts")}
        {lang}
        class="self-start md:pt-[.27lh] md:col-start-2 md:row-start-1 md:justify-self-end"
      />
    </div>
  </section>

  <section class="section xl:py-section-sm">
    <SectionHeading title={t(lang, "blog.topics")} />
    <TagList tags={allTags} {lang} class="mb-section-sm" />

    <ul
      class="grid grid-cols-1 gap-y-section-sm md:grid-cols-2 md:gap-x-10 xl:*:w-full xl:*:max-w-156"
    >
      <!-- xl:*:not-first:justify-self-end -->
      {
        tagSections.map((section) => (
          <li>
            <h3 class="text-title-sm mb-[.66em]">{section.title}</h3>
            <ul class="flex flex-col gap-4 mb-4 sm:max-md:flex-row">
              {section.posts.map((post) => (
                <li>
                  <PostCard
                    {post}
                    {lang}
                    level={4}
                    size="sm"
                    imageMode="right"
                    noDescription
                    meta="none"
                    headingClass="mb-0 max-w-[24ch]"
                  />
                </li>
              ))}
            </ul>
            <SeeAllLink
              href={localePath(`blog/topics/${section.slug}`)}
              {lang}
              size="sm"
            />
          </li>
        ))
      }
    </ul>
  </section>
</Base>
