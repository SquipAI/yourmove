---
import Base from "@layouts/Base.astro";
import PostList from "@components/blog/ui/PostList.astro";
import PageHeading from "@components/ui/PageHeading.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { PostCard as PostCardType, BlogSubPageData } from "@lib/types";

interface Props {
  posts: PostCardType[];
  page: BlogSubPageData;
  lang?: Locale;
}

const { posts, page, lang = DEFAULT_LOCALE } = Astro.props;
const count =
  posts.length === 1 ? t(lang, "blog.article") : t(lang, "blog.articles");
---

<Base title={page.metaTitle} description={page.metaDescription} {lang}>
  <section class="section">
    <PageHeading
      title={page?.title ?? t(lang, "blog.allPosts")}
      subtitle={`${posts.length} ${count}`}
    />

    <PostList {posts} {lang} priorityCount={2} />
  </section>
</Base>
