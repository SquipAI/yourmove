---
import Base from "@layouts/Base.astro";
import PostList from "@components/blog/ui/PostList.astro";
import TagList from "@components/blog/ui/TagList.astro";
import PageHeading from "@components/ui/PageHeading.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type {
  PostCard as PostCardType,
  TagPageData,
  TagWithCount,
} from "@lib/types";

interface Props {
  posts: PostCardType[];
  tag: TagPageData;
  otherTags: TagWithCount[];
  lang?: Locale;
}

const { posts, tag, otherTags, lang = DEFAULT_LOCALE } = Astro.props;
const count =
  posts.length === 1 ? t(lang, "blog.article") : t(lang, "blog.articles");
---

<Base title={tag.metaTitle} description={tag.metaDescription} {lang}>
  <section class="section">
    <PageHeading
      title={tag.title ?? t(lang, "blog.topics")}
      subtitle={`${posts.length} ${count}`}
    />

    <PostList {posts} {lang} priorityCount={2} />
  </section>

  <section class="section pt-0">
    <SectionHeading
      eyebrow={t(lang, "blog.explore")}
      title={t(lang, "blog.moreTopics")}
      size="sm"
    />

    <TagList tags={otherTags} {lang} />
  </section>
</Base>
