---
import { Image } from "astro:assets";
import Base from "@layouts/Base.astro";
import PortableText from "@components/ui/PortableText.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { Post, PostCard } from "@lib/types";

interface Props {
  post: Post;
  related: PostCard[];
  lang?: Locale;
}

const { post, related, lang = DEFAULT_LOCALE } = Astro.props;
---

<Base title={post.metaTitle} description={post.metaDescription} {lang}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight mb-3">{post.title}</h1>
      {post.summary && <p class="text-lg text-gray-600">{post.summary}</p>}
    </header>

    {post.mainImage?.url && (
      <Image
        src={post.mainImage.url}
        alt={post.mainImage.alt ?? post.title}
        width={900}
        height={500}
        loading="eager"
        class="w-full h-auto rounded-xl mb-10"
      />
    )}

    <div class="prose prose-lg max-w-none">
      <PortableText body={post.body ?? []} faq={post.faq} />
    </div>
  </article>
</Base>
