---
import Base from "@layouts/Base.astro";
import TagCard from "@components/blog/ui/TagCard.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { TagWithCount, BlogSubPageData } from "@lib/types";

interface Props {
  tags: TagWithCount[];
  page: BlogSubPageData;
  lang?: Locale;
}

const { tags, page, lang = DEFAULT_LOCALE } = Astro.props;
---

<Base title={page.metaTitle} description={page.metaDescription} {lang}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold mb-8">{page?.title ?? t(lang, "blog.topics")}</h1>
    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
      {tags.map((tag) => <li><TagCard {tag} {lang} /></li>)}
    </ul>
  </section>
</Base>
