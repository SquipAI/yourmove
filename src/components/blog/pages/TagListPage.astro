---
import Base from "@layouts/Base.astro";
import PageHeading from "@components/ui/PageHeading.astro";
import TagCard from "@components/blog/ui/TagCard.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { TagWithCount, BlogSubPageData } from "@lib/types";

interface Props {
  tags: TagWithCount[];
  page: BlogSubPageData;
  lang?: Locale;
}

const { tags, page, lang = DEFAULT_LOCALE } = Astro.props;
---

<Base title={page.metaTitle} description={page.metaDescription} {lang}>
  <section class="section">
    <PageHeading title={page?.title ?? t(lang, "blog.topics")} />
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tags.map((tag) => <TagCard {tag} {lang} />)}
    </ul>
  </section>
</Base>
