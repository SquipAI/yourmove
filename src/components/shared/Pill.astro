---
interface Props {
  href: string;
  label: string;
  variant?: "default" | "brand";
  /** Optional trailing count */
  count?: number | string | null;
  class?: string;
}

const { href, label, variant = "default", count, class: cls } = Astro.props;

const variantClass = {
  default:
    "text-subtle border-subtle-lighter hover:border-brand hover:text-brand",
  brand: "text-brand border-brand hover:bg-brand hover:text-white",
}[variant];
---

<a
  href={href}
  class:list={[
    "inline-flex shrink-0 items-center gap-[6px] px-4 py-1.5 bg-white text-sm whitespace-nowrap border rounded-full transition-colors",
    variantClass,
    cls,
  ]}
>
  {label}
  {count != null && <span class="text-xs">{count}</span>}
</a>
