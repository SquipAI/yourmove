---
import SectionHeading from "@components/shared/SectionHeading.astro";
import { t } from "@i18n/ui";
import Apple from "@assets/svg/apple.svg";
import Google from "@assets/svg/google.svg";
import type { Locale } from "@i18n/config";

interface Props {
  /** download — store badges + shared subtext (listing/content pages).
   *  promo — per-tool conversion button + one OS-aware store button. */
  variant?: "download" | "promo";
  heading: string;
  /** Optional sentence under the heading. Shown only when set. */
  subtitle?: string | null;
  userCount: string;
  userRating: string;
  appStoreUrl: string;
  playStoreUrl: string;
  /** Text under the buttons. Defaults to the shared store line on `download`. */
  subtext?: string | null;
  /** promo only — primary conversion button. */
  buttonText?: string;
  href?: string;
  lang: Locale;
  class?: string;
}

const {
  variant = "download",
  heading,
  subtitle,
  userCount,
  userRating,
  appStoreUrl,
  playStoreUrl,
  subtext,
  buttonText,
  href,
  lang,
  class: cls,
} = Astro.props;

const isPromo = variant === "promo";

// Stats eyebrow — shown on both variants. Split the ★ run so it tints gold.
const eyebrow = t(lang, "download.eyebrow")
  .replace("{count}", userCount)
  .replace("{rating}", userRating);
const eyebrowParts = eyebrow.split(/(★+)/);

// Under-button line: explicit subtext, else the shared store line on download.
const footer = subtext ?? (isPromo ? null : t(lang, "download.subtext"));
---

{
  isPromo && (
    <script is:inline>
      if (/Android/i.test(navigator.userAgent))
      document.documentElement.classList.add("os-android");
    </script>
  )
}

<section
  data-section={isPromo ? "cta" : undefined}
  class:list={["section", cls]}
>
  <div
    class="flex flex-col items-center px-svw py-section text-center text-white bg-radial-[ellipse_110%_90%_at_50%_89%] from-brand-darkest via-brand-darker to-brand rounded-xl md:rounded-3xl md:py-section-sm"
  >
    <p class="tracking-eyebrow text-xs font-medium uppercase opacity-80 mb-2">
      {
        eyebrowParts.map((part) =>
          part.includes("★") ? <span class="text-gold">{part}</span> : part,
        )
      }
    </p>

    <SectionHeading
      title={heading}
      {subtitle}
      class="max-w-3xl [--color-brand-darker:var(--color-gold)] [--color-subtle:var(--color-subtle-on-brand)]"
    />

    {
      isPromo ? (
        <div class="mb-2 flex w-full flex-col items-center justify-center gap-3 sm:w-auto sm:flex-row">
          <a
            href={href}
            class="text-brand hover:bg-brand-darker inline-flex h-12 w-full items-center justify-center gap-2 rounded-lg bg-white px-6 font-medium transition-colors hover:text-white sm:w-auto sm:min-w-45"
          >
            {buttonText}
            <span aria-hidden="true">→</span>
          </a>
          {appStoreUrl && (
            <a
              href={appStoreUrl}
              class="border-white/35 hover:bg-white/10 inline-flex h-12 w-full items-center justify-center rounded-lg border px-6 font-medium text-white transition-colors sm:w-auto [html.os-android_&]:hidden"
            >
              {t(lang, "store.getOnIos")}
            </a>
          )}
          {playStoreUrl && (
            <a
              href={playStoreUrl}
              class="border-white/35 hover:bg-white/10 hidden h-12 w-full items-center justify-center rounded-lg border px-6 font-medium text-white transition-colors sm:w-auto [html.os-android_&]:inline-flex"
            >
              {t(lang, "store.getOnAndroid")}
            </a>
          )}
        </div>
      ) : (
        <div class="mb-2 flex flex-wrap justify-center items-center gap-4 [&_svg]:h-11 [&_svg]:w-auto">
          <a
            href={appStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t(lang, "store.appStore")}
            class="inline-flex items-center transition hover:-translate-y-px hover:shadow-md active:translate-y-0 active:shadow-sm"
          >
            <Apple aria-hidden="true" />
          </a>
          <a
            href={playStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t(lang, "store.playStore")}
            class="inline-flex items-center transition hover:-translate-y-px hover:shadow-md active:translate-y-0 active:shadow-sm"
          >
            <Google aria-hidden="true" />
          </a>
        </div>
      )
    }

    {footer && <p class="text-sm opacity-80">{footer}</p>}
  </div>
</section>
