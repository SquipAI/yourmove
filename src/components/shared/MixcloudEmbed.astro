---
import { Image } from "astro:assets";
import type { SanityImageSource } from "@sanity/image-url";
import { urlFor } from "@lib/sanity-image";

interface Props {
  feed: string;
  title?: string;
  image?: SanityImageSource;
}

const { feed, title, image } = Astro.props;
const src = `https://www.mixcloud.com/widget/iframe/?feed=${encodeURIComponent(feed)}&autoplay=1`;
---

<div class="not-prose my-6" data-mixcloud-facade data-src={src}>
  <button
    type="button"
    class="bg-dark/80 flex h-15 w-full cursor-pointer items-stretch overflow-hidden rounded-lg text-left text-white transition-colors hover:bg-dark/70"
    data-mixcloud-play
  >
    {
      image && (
        <Image
          src={urlFor(image).width(60).height(60).fit("crop").url()}
          alt=""
          width={60}
          height={60}
          class="w-[60px] shrink-0 self-stretch object-cover"
        />
      )
    }
    <span
      class:list={[
        "flex items-center gap-2 py-2 pr-4",
        image ? "pl-3" : "pl-4",
      ]}
    >
      <span
        aria-hidden="true"
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/15 text-lg"
      >
        ▶
      </span>
      <span class="flex flex-col gap-0.5 overflow-hidden">
        <span class="truncate text-sm font-semibold">
          {title ?? "Play on Mixcloud"}
        </span>
        <span class="text-xs text-white/60">Mixcloud</span>
      </span>
    </span>
  </button>
</div>

<script>
  document
    .querySelectorAll<HTMLElement>("[data-mixcloud-facade]")
    .forEach((facade) => {
      facade.querySelector("[data-mixcloud-play]")?.addEventListener(
        "click",
        () => {
          const src = facade.dataset.src;
          if (!src) return;
          const iframe = document.createElement("iframe");
          iframe.src = src;
          iframe.title = "Mixcloud";
          iframe.allow = "autoplay";
          iframe.className = "h-[60px] w-full";
          facade.replaceChildren(iframe);
        },
        { once: true },
      );
    });
</script>
