---
import { parseAccent } from "@lib/parseAccent";
import Eyebrow from "@components/shared/Eyebrow.astro";

interface Props {
  title: string;
  eyebrow?: string | null;
  subtitle?: string | null;
  level?: 1 | 2;
  size?: "default" | "big";
  subtitleSize?: "default" | "sm";
  class?: string;
}

const {
  title,
  eyebrow,
  subtitle,
  level = 1,
  size = "default",
  subtitleSize = "default",
  class: cls,
} = Astro.props;

const Tag = `h${level}` as "h1" | "h2";
const isBig = size === "big";
const titleParts = parseAccent(title);
const subtitleParts = parseAccent(subtitle);
const subtitleClass =
  subtitleSize === "sm"
    ? "text-subtitle-sm"
    : isBig
      ? "text-subtitle"
      : "text-xl";
const hasExtras = !!eyebrow || !!subtitle;
---

{
  hasExtras ? (
    <hgroup class:list={["not-last:mb-section-xs *:max-w-150", cls]}>
      {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
      <Tag class:list={[isBig ? "text-title-big" : "text-title"]}>
        {titleParts.map((p) =>
          p.accent ? <span class="text-brand italic">{p.text}</span> : p.text,
        )}
      </Tag>
      {subtitle && (
        <p class={subtitleClass}>
          {subtitleParts.map((p) =>
            p.accent ? <span class="text-brand italic">{p.text}</span> : p.text,
          )}
        </p>
      )}
    </hgroup>
  ) : (
    <Tag
      class:list={[
        isBig ? "text-title-big" : "text-title",
        "mb-section-xs",
        cls,
      ]}
    >
      {titleParts.map((p) =>
        p.accent ? <span class="text-brand italic">{p.text}</span> : p.text,
      )}
    </Tag>
  )
}
