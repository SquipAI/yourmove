---
import { parseAccent } from "@lib/parseAccent";
import Breadcrumbs, {
  type BreadcrumbItem,
} from "@components/shared/Breadcrumbs.astro";
import Eyebrow from "@components/shared/Eyebrow.astro";

interface Props {
  title: string;
  eyebrow?: string | null;
  /** Visual variant for the eyebrow. `pill` = rounded tinted background. */
  eyebrowVariant?: "default" | "pill";
  /** Breadcrumbs rendered above the heading. */
  breadcrumbs?: BreadcrumbItem[];
  subtitle?: string | null;
  level?: 1 | 2;
  size?: "default" | "big";
  /** Center the eyebrow/title/subtitle horizontally. */
  centered?: boolean;
  class?: string;
}

const {
  title,
  eyebrow,
  eyebrowVariant = "default",
  breadcrumbs,
  subtitle,
  level = 1,
  size = "default",
  centered = false,
  class: cls,
} = Astro.props;

const Tag = `h${level}` as "h1" | "h2";
const isBig = size === "big";
const titleParts = parseAccent(title);
const subtitleParts = parseAccent(subtitle);
const hasExtras = !!eyebrow || !!subtitle;
---

{breadcrumbs && breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}

{
  hasExtras ? (
    <hgroup
      class:list={[
        "flex flex-col not-last:mb-section-xs lg:not-last:mb-svw md:*:max-w-210",
        centered && "items-center text-center",
        cls,
      ]}
    >
      {eyebrow && <Eyebrow variant={eyebrowVariant}>{eyebrow}</Eyebrow>}
      <Tag
        class:list={[isBig ? "text-title-big" : "text-title", "font-semibold"]}
      >
        {titleParts.map((p) =>
          p.accent ? <span class="accent">{p.text}</span> : p.text,
        )}
      </Tag>
      {subtitle && (
        <p class="text-subtitle text-balance">
          {subtitleParts.map((p) =>
            p.accent ? <span class="accent">{p.text}</span> : p.text,
          )}
        </p>
      )}
    </hgroup>
  ) : (
    <Tag
      class:list={[
        isBig ? "text-title-big" : "text-title",
        "mb-section-xs max-w-210 lg:mb-svw font-semibold",
        centered && "mx-auto text-center",
        cls,
      ]}
    >
      {titleParts.map((p) =>
        p.accent ? <span class="accent">{p.text}</span> : p.text,
      )}
    </Tag>
  )
}
