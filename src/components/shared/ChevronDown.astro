---
interface Props {
  // "select": absolute-positioned overlay chevron for a custom <select> wrapper.
  variant?: "select";
  class?: string;
}

const { variant, class: cls } = Astro.props;

const variantClass =
  variant === "select"
    ? "pointer-events-none absolute right-3 top-1/2 size-4 -translate-y-1/2 text-subtle"
    : undefined;
---

<svg
  class:list={["chevron", variantClass, cls]}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  aria-hidden="true"
>
  <path d="M6 9l6 6 6-6"></path>
</svg>
