---
import Apple from "@assets/svg/apple.svg";
import Google from "@assets/svg/google.svg";
import SectionHeading from "@components/shared/SectionHeading.astro";
import { t } from "@i18n/ui";
import type { Locale } from "@i18n/config";

interface Props {
  heading: string;
  userCount: string;
  userRating: string;
  appStoreUrl: string;
  playStoreUrl: string;
  lang: Locale;
  class?: string;
}

const {
  heading,
  userCount,
  userRating,
  appStoreUrl,
  playStoreUrl,
  lang,
  class: cls,
} = Astro.props;

// Eyebrow (stats) + subtext are identical on every page → i18n, not Sanity.
const eyebrow = t(lang, "download.eyebrow")
  .replace("{count}", userCount)
  .replace("{rating}", userRating);
const subtext = t(lang, "download.subtext");

// Split out the ★ run so it can be tinted gold, rest of the eyebrow stays plain.
const eyebrowParts = eyebrow.split(/(★+)/);
---

<section class:list={["section ", cls]}>
  <div
    class="flex flex-col items-center px-svw py-section text-center text-white bg-radial-[ellipse_110%_90%_at_50%_89%] from-brand-darkest via-brand-darker to-brand rounded-xl md:rounded-3xl md:py-section-sm"
  >
    <p class="tracking-eyebrow text-xs font-medium uppercase opacity-80 mb-2">
      {
        eyebrowParts.map((part) =>
          part.includes("★") ? <span class="text-gold">{part}</span> : part,
        )
      }
    </p>
    <SectionHeading
      title={heading}
      class="max-w-3xl font-bold [--color-brand:var(--color-gold)]"
    />
    <div
      class="mb-2 flex flex-wrap justify-center items-center gap-4 [&_svg]:h-11 [&_svg]:w-auto"
    >
      <a
        href={appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t(lang, "store.appStore")}
        class="inline-flex items-center transition hover:-translate-y-px hover:shadow-md active:translate-y-0 active:shadow-sm"
      >
        <Apple aria-hidden="true" />
      </a>
      <a
        href={playStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t(lang, "store.playStore")}
        class="inline-flex items-center transition hover:-translate-y-px hover:shadow-md active:translate-y-0 active:shadow-sm"
      >
        <Google aria-hidden="true" />
      </a>
    </div>
    <p class="text-sm opacity-80">{subtext}</p>
  </div>
</section>
