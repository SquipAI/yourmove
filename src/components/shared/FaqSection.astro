---
import type { FaqItem } from "@lib/types";
import { inlineHTML, type TextBlock } from "@lib/portableText";
import ChevronDown from "@components/shared/ChevronDown.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import type { Locale } from "@i18n/config";

interface Props {
  items: FaqItem[];
  heading: string;
  eyebrow?: string | null;
  subtitle?: string | null;
  /** Heading level for the section title. Default 2. */
  level?: 2 | 3;
  /** Horizontal alignment. Default "start". */
  align?: "center" | "start";
  lang: Locale;
}

const {
  items,
  heading,
  eyebrow,
  subtitle,
  level = 2,
  align = "start",
  lang,
} = Astro.props;

const wrapperAlign = align === "center" ? "items-center" : "items-start";
const headingAlign = align === "center" ? "text-center" : undefined;
---

<section data-section="faq" class="section">
  <div class:list={["flex flex-col", wrapperAlign]}>
    <SectionHeading
      title={heading}
      {eyebrow}
      {subtitle}
      {level}
      class={headingAlign}
    />
    <ul class="flex flex-col gap-2 w-full sm:max-w-156">
      {
        items.map((item) => (
          <li>
            <details class="p-svw bg-white rounded-md border border-subtle-lighter sm:p-4">
              <summary class="justify-between gap-4 font-medium text-pretty">
                <h3 class="mb-0">{item.question}</h3>
                <ChevronDown />
              </summary>
              <div class="flex flex-col gap-3 pt-4">
                {(item.answer as TextBlock[] | undefined)?.map((block) => {
                  if (block._type !== "block") return null;
                  return (
                    <p
                      set:html={inlineHTML(
                        block.children,
                        block.markDefs,
                        lang,
                      )}
                    />
                  );
                })}
              </div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</section>
