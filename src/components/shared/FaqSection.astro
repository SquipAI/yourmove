---
import type { FaqItem } from "@lib/types";
import FaqAnswer from "@components/shared/FaqAnswer.astro";
import ChevronDown from "@components/shared/ChevronDown.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import type { Locale } from "@i18n/config";

interface Props {
  items: FaqItem[];
  heading: string;
  eyebrow?: string | null;
  subtitle?: string | null;
  /** Horizontal alignment. Default "start". */
  align?: "center" | "start";
  lang: Locale;
}

const {
  items,
  heading,
  eyebrow,
  subtitle,
  align = "start",
  lang,
} = Astro.props;

const wrapperAlign = align === "center" ? "items-center" : "items-start";
const headingAlign = align === "center" ? "text-center" : undefined;
---

<section data-section="faq" class="section">
  <div class:list={["flex flex-col", wrapperAlign]}>
    <SectionHeading
      title={heading}
      {eyebrow}
      {subtitle}
      class={headingAlign}
      size="sm"
    />
    <ul class="flex flex-col w-full sm:max-w-156">
      {
        items.map((item) => (
          <li>
            <details class="px-2 border-b border-subtle/30">
              <summary class="justify-between gap-4 font-medium text-pretty py-svw sm:py-4 hover:text-brand-darker">
                <h3 class="mb-0">{item.question}</h3>
                <ChevronDown />
              </summary>
              <div class="flex flex-col gap-3 pb-svw sm:pb-4">
                <FaqAnswer answer={item.answer} {lang} />
              </div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</section>
