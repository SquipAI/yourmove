---
interface Props {
  /** Visual variant. `pill` adds tinted background, padding and rounded shape. */
  variant?: "default" | "pill";
  class?: string;
}

const { variant = "default", class: cls } = Astro.props;
const isPill = variant === "pill";
---

<p
  class:list={[
    "tracking-eyebrow text-brand flex items-center gap-2 text-xs font-medium uppercase",
    isPill &&
      "bg-brand-lighter/25 w-fit rounded-full px-3 py-1.5 my-2 text-brand-darker",
    cls,
  ]}
>
  <slot />
</p>
