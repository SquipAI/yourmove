---
import { Image } from "astro:assets";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { inlineHTML, type TextBlock } from "@lib/portableText";
import { resolveNavHref } from "@lib/links";
import FaqAnswer from "@components/shared/FaqAnswer.astro";
import MixcloudEmbed from "@components/shared/MixcloudEmbed.astro";
import type { Locale } from "@i18n/config";
import type { SanityImageSource } from "@sanity/image-url";
import { t } from "@i18n/ui";

// ── Block types specific to body rendering ────────────────────────────────────

type ImageBlock = {
  _key: string;
  _type: "image";
  url?: string;
  width?: number;
  height?: number;
  alt?: string;
  fullWidth?: boolean;
};

type EmbedBlock = {
  _key: string;
  _type: "embed";
  kind: "youtube" | "mixcloud" | "googleSlides" | "document";
  source?: string;
  doc?: { _type: string; title?: string; slug?: string | null } | null;
};

type HtmlEmbedBlock = {
  _key: string;
  _type: "htmlEmbed";
  code: string;
};

type FaqSectionBlock = {
  _key: string;
  _type: "faqSection";
  heading?: string;
  subheading?: string;
};

type StatSectionBlock = {
  _key: string;
  _type: "statSection";
  heading?: string;
  subheading?: string;
};

type Block =
  | TextBlock
  | ImageBlock
  | EmbedBlock
  | HtmlEmbedBlock
  | FaqSectionBlock
  | StatSectionBlock;

type Chunk =
  | { kind: "block"; block: TextBlock }
  | { kind: "list"; listItem: "bullet" | "number"; items: TextBlock[] }
  | { kind: "image"; block: ImageBlock }
  | { kind: "embed"; block: EmbedBlock }
  | { kind: "htmlEmbed"; block: HtmlEmbedBlock }
  | { kind: "faqSection"; block: FaqSectionBlock }
  | { kind: "statSection"; block: StatSectionBlock };

type FaqItem = {
  _key: string;
  question: string;
  answer: unknown[];
};

type StatItem = {
  _key: string;
  title: string;
  description?: unknown[] | null;
  source?: string | null;
  sourceUrl?: string | null;
};

interface Props {
  body: unknown[];
  faq?: FaqItem[] | null;
  stats?: StatItem[] | null;
  postTitle?: string;
  postImage?: SanityImageSource;
  lang: Locale;
}

const { body, faq, stats, postTitle, postImage, lang } = Astro.props;

// ── Embed helpers ─────────────────────────────────────────────────────────────

function youtubeId(source: string): string | null {
  const m = source.match(
    /(?:youtu\.be\/|youtube\.com\/(?:embed\/|watch\?v=|v\/|shorts\/))([\w-]{11})/,
  );
  if (m) return m[1];
  if (/^[\w-]{11}$/.test(source)) return source;
  return null;
}

// ── Group consecutive list items ───────────────────────────────────────────────

const chunks: Chunk[] = [];
for (const raw of body as Block[]) {
  if (raw._type === "image") {
    chunks.push({ kind: "image", block: raw });
  } else if (raw._type === "embed") {
    chunks.push({ kind: "embed", block: raw });
  } else if (raw._type === "htmlEmbed") {
    chunks.push({ kind: "htmlEmbed", block: raw });
  } else if (raw._type === "faqSection") {
    chunks.push({ kind: "faqSection", block: raw });
  } else if (raw._type === "statSection") {
    chunks.push({ kind: "statSection", block: raw });
  } else if (raw._type === "block" && raw.listItem) {
    const last = chunks.at(-1);
    if (last?.kind === "list" && last.listItem === raw.listItem) {
      last.items.push(raw);
    } else {
      chunks.push({ kind: "list", listItem: raw.listItem, items: [raw] });
    }
  } else if (raw._type === "block") {
    chunks.push({ kind: "block", block: raw });
  }
}
---

{
  chunks.map((chunk) => {
    if (chunk.kind === "image") {
      const { block } = chunk;
      if (!block.url || !block.width || !block.height) return null;
      return (
        <Image
          src={block.url}
          alt={block.alt ?? ""}
          width={block.width}
          height={block.height}
          loading="lazy"
          class:list={[
            "h-auto w-full max-w-full rounded-lg",
            !block.fullWidth && "min-[450px]:max-w-[400px]",
          ]}
        />
      );
    }

    if (chunk.kind === "embed") {
      const { block } = chunk;
      // Source media (YouTube/Mixcloud/Slides) is only prepared in EN —
      // ES/DE posts don't have a localized version of the embed itself.
      if (
        lang !== "en" &&
        (block.kind === "youtube" ||
          block.kind === "mixcloud" ||
          block.kind === "googleSlides")
      ) {
        return null;
      }
      if (block.kind === "youtube" && block.source) {
        const id = youtubeId(block.source);
        if (!id) return null;
        // Facade embed (lite-youtube): renders a poster image and only
        // loads the real player iframe on click — keeps these posts fast.
        return (
          <div class="not-prose my-6 overflow-hidden rounded-lg">
            <YouTube id={id} title="YouTube video" class="w-full max-w-none!" />
          </div>
        );
      }
      if (block.kind === "mixcloud" && block.source) {
        // Click-to-load facade — the real widget grabs the Media Session
        // (headphone play/pause/skip) the moment its iframe mounts, even
        // unplayed, so it must not load until the reader opts in.
        return (
          <MixcloudEmbed
            feed={block.source}
            title={postTitle}
            image={postImage}
          />
        );
      }
      if (block.kind === "googleSlides" && block.source) {
        return (
          <div class="not-prose my-6 aspect-video">
            <iframe
              src={block.source}
              title="Google Slides"
              loading="lazy"
              class="h-full w-full rounded-lg"
              allowfullscreen
            />
          </div>
        );
      }
      if (block.kind === "document" && block.doc?.slug) {
        const href = resolveNavHref(block.doc._type, block.doc.slug, null, lang);
        if (!href) return null;
        return (
          <a href={href} class="card not-prose my-6 p-4">
            <span class="text-subtle text-sm tracking-eyebrow uppercase">
              {block.doc._type}
            </span>
            <div class="font-medium">{block.doc.title}</div>
          </a>
        );
      }
      return null;
    }

    if (chunk.kind === "htmlEmbed") {
      return <div class="not-prose my-6" set:html={chunk.block.code} />;
    }

    if (chunk.kind === "faqSection") {
      // Marker block — pulls the document's faq[] items in here so the
      // heading sits directly above its list (same place the original
      // Webflow source had them). Answer rendering (paragraphs + lists) is
      // shared with FaqSection via FaqAnswer.
      if (!faq?.length) return null;
      return (
        <section>
          {chunk.block.heading && <h2>{chunk.block.heading}</h2>}
          {chunk.block.subheading && <p>{chunk.block.subheading}</p>}
          <dl>
            {faq.map((item) => (
              <div class="mb-6">
                <dt class="mb-2 text-lg font-semibold">{item.question}</dt>
                <dd>
                  <FaqAnswer answer={item.answer} {lang} />
                </dd>
              </div>
            ))}
          </dl>
        </section>
      );
    }

    if (chunk.kind === "statSection") {
      // Marker block — pulls the document's stats[] in here as cards (mirrors
      // the faqSection field/marker split). The section H2 usually already
      // sits above this marker as a normal body block.
      if (!stats?.length) return null;
      return (
        <section class="stat-section">
          {chunk.block.heading && <h2>{chunk.block.heading}</h2>}
          {chunk.block.subheading && <p>{chunk.block.subheading}</p>}
          <ul>
            {stats.map((stat) => (
              <li class="stat-card">
                <p>{stat.title}</p>
                {stat.description && (
                  <FaqAnswer answer={stat.description} {lang} />
                )}
                {stat.source && (
                  <p>
                    <span class="font-semibold">{t(lang, "blog.source")}</span>{" "}
                    {stat.sourceUrl ? (
                      <a
                        href={stat.sourceUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {stat.source}
                      </a>
                    ) : (
                      <span class="text-brand">{stat.source}</span>
                    )}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </section>
      );
    }

    if (chunk.kind === "list") {
      const Tag = chunk.listItem === "bullet" ? "ul" : "ol";
      return (
        <Tag>
          {chunk.items.map((item) => (
            <li set:html={inlineHTML(item.children, item.markDefs, lang)} />
          ))}
        </Tag>
      );
    }

    const { block } = chunk;
    const html = inlineHTML(block.children, block.markDefs, lang);
    if (block.style === "h2") return <h2 set:html={html} />;
    if (block.style === "h3") return <h3 set:html={html} />;
    if (block.style === "h4") return <h4 set:html={html} />;
    if (block.style === "h5") return <h5 set:html={html} />;
    if (block.style === "blockquote") return <blockquote set:html={html} />;
    return <p set:html={html} />;
  })
}
