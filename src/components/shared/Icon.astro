---
// Lucide icon registry. SVGs live in src/assets/icons/ (one file per icon).
// Editor-pickable feature icons are declared in @lib/icons (Studio reads the
// same list); the assignment below fails to compile if one is missing here.
import type { FeatureIconName } from "@lib/icons";

import ArrowRight from "@assets/icons/arrow-right.svg";
import Camera from "@assets/icons/camera.svg";
import Check from "@assets/icons/check.svg";
import Clock from "@assets/icons/clock.svg";
import Copy from "@assets/icons/copy.svg";
import Heart from "@assets/icons/heart.svg";
import Loader from "@assets/icons/loader.svg";
import LockOpen from "@assets/icons/lock-open.svg";
import MessageCircle from "@assets/icons/message-circle.svg";
import PenTool from "@assets/icons/pen-tool.svg";
import RotateCw from "@assets/icons/rotate-cw.svg";
import SlidersHorizontal from "@assets/icons/sliders-horizontal.svg";
import Sparkles from "@assets/icons/sparkles.svg";
import Star from "@assets/icons/star.svg";
import ThumbsUp from "@assets/icons/thumbs-up.svg";
import TrendingUp from "@assets/icons/trending-up.svg";
import X from "@assets/icons/x.svg";
import Zap from "@assets/icons/zap.svg";

const ICONS = {
  "arrow-right": ArrowRight,
  "trending-up": TrendingUp,
  heart: Heart,
  "pen-tool": PenTool,
  "message-circle": MessageCircle,
  star: Star,
  "thumbs-up": ThumbsUp,
  loader: Loader,
  clock: Clock,
  zap: Zap,
  sparkles: Sparkles,
  check: Check,
  camera: Camera,
  copy: Copy,
  "rotate-cw": RotateCw,
  "lock-open": LockOpen,
  "sliders-horizontal": SlidersHorizontal,
  x: X,
};

export type IconName = keyof typeof ICONS;

const _featureIconsRegistered: Record<FeatureIconName, unknown> = ICONS;
void _featureIconsRegistered;

interface Props {
  name: IconName;
  class?: string;
  stroke?: string;
  fill?: string;
  strokeWidth?: string;
}

const {
  name,
  class: cls = "size-6",
  stroke = "currentColor",
  fill = "none",
  strokeWidth = "2",
} = Astro.props;

const Component = ICONS[name];
---

<Component
  class={cls}
  stroke={stroke}
  fill={fill}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
/>
