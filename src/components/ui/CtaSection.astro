---
import PageHeading from "@components/ui/PageHeading.astro";
import Btn from "@components/ui/Btn.astro";
import { resolveNavHref } from "@lib/navHref";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { CtaLink } from "@lib/types";

const DEFAULT_HREF = "https://web.yourmove.ai/start";

interface Props {
  title: string;
  subtitle?: string | null;
  buttonText: string;
  buttonLink?: CtaLink | null;
  lang?: Locale;
}

const {
  title,
  subtitle,
  buttonText,
  buttonLink,
  lang = DEFAULT_LOCALE,
} = Astro.props;

const href =
  resolveNavHref(
    buttonLink?.targetType,
    buttonLink?.targetSlug,
    buttonLink?.externalUrl,
    lang,
  ) ?? DEFAULT_HREF;
---

<div class="flex flex-col items-center text-center">
  <PageHeading
    title={title}
    subtitle={subtitle}
    level={2}
    class="*:mx-auto *:text-center"
  />
  <Btn href={href} class="btn-big mt-section-xs">
    {buttonText} <span aria-hidden="true" class="ml-2">→</span>
  </Btn>
</div>
