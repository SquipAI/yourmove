---
interface Props {
  /** CSS color. If omitted, defaults to brand. Pass "currentColor" to follow text. */
  color?: string;
  class?: string;
}

const { color, class: cls } = Astro.props;
---

<span
  class:list={[
    "aspect-square h-[6px] shrink-0 rounded-full bg-(--dot-color)",
    cls,
  ]}
  style={`--dot-color: ${color ?? "var(--color-brand)"}`}
  aria-hidden="true"></span>
