---
import { getRelativeLocaleUrl } from "astro:i18n";

import ExtendedHero from "@components/tools/ExtendedHero.astro";
import LogoRow from "@components/shared/LogoRow.astro";
import Examples from "@components/tools/ui/Examples.astro";
import SocialProof from "@components/tools/ui/SocialProof.astro";
import CtaSection from "@components/shared/CtaSection.astro";
import FaqSection from "@components/shared/FaqSection.astro";
import FeaturesSection from "@components/tools/FeaturesSection.astro";
import HowItWorksSection from "@components/tools/HowItWorksSection.astro";
import ToolListSection from "@components/tools/ToolListSection.astro";
import TestimonialsSection from "@components/testimonials/TestimonialsSection.astro";

import { getCompatibilityApps } from "@lib/queries";
import { stripAccent } from "@lib/parseAccent";
import { t } from "@i18n/ui";
import type { Locale } from "@i18n/config";
import type { ToolPageData, Testimonial } from "@lib/types";

interface Props {
  tool: ToolPageData;
  lang: Locale;
  ctaHref: string | null;
  testimonials: Testimonial[];
  showTestimonials: boolean;
}

const { tool, lang, ctaHref, testimonials, showTestimonials } = Astro.props;
const hero = tool.extendedHero!;
const compatibilityApps = await getCompatibilityApps(tool.app?._id ?? null);

const breadcrumbItems = [
  { name: tool.toolsNavLabel, url: getRelativeLocaleUrl(lang, "tools") },
  ...(tool.app
    ? [
        {
          name: tool.app.name,
          url: getRelativeLocaleUrl(lang, `tools/${tool.app.slug}`),
        },
      ]
    : []),
  { name: tool.cardTitle ?? tool.title },
];

const compatibilityLabel = tool.app
  ? t(lang, "tools.alsoCompatibleWith")
  : t(lang, "tools.compatibleWith");
---

<ExtendedHero {tool} {hero} {breadcrumbItems} {lang}>
  <div class="flex flex-col gap-y-[24px]">
    <LogoRow logos={compatibilityApps} label={compatibilityLabel} />
    <SocialProof text={hero.socialProof} />
  </div>
</ExtendedHero>

<section class="section">
  <Examples
    heading={tool.examplesHeading!}
    subtitle={tool.examplesSubtitle}
    items={tool.examples!}
    {lang}
  />
</section>

{
  tool.howItWorks && tool.howItWorks.length > 0 && tool.howItWorksHeading && (
    <HowItWorksSection
      steps={tool.howItWorks}
      heading={tool.howItWorksHeading}
      ctaText={tool.cta?.buttonText ?? t(lang, "howItWorks.cta")}
      ctaHref={ctaHref ?? "#"}
      ctaSubtext={tool.howItWorksCtaSubtext}
      {lang}
    />
  )
}

{
  tool.features && tool.features.length > 0 && tool.featuresHeading && (
    <FeaturesSection
      items={tool.features}
      heading={tool.featuresHeading}
      eyebrow={tool.featuresEyebrow}
      {lang}
    />
  )
}

{
  showTestimonials && (
    <TestimonialsSection
      {testimonials}
      heading={t(lang, "reviews.heading")}
      {lang}
    />
  )
}

{
  tool.cta && (
    <CtaSection
      title={tool.cta.title}
      subtitle={tool.cta.subtitle}
      buttonText={tool.cta.buttonText}
      href={ctaHref!}
    />
  )
}

{
  tool.faq && tool.faq.length > 0 && (
    <FaqSection
      items={tool.faq}
      heading={
        tool.faqHeading ?? `${tool.cardTitle ?? stripAccent(tool.title)} FAQ`
      }
      {lang}
    />
  )
}

<ToolListSection data={tool.toolList!} {lang} />
