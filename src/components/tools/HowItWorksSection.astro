---
import { DEFAULT_LOCALE, type Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { HowItWorksStep } from "@lib/types";
import SectionHeading from "@components/shared/SectionHeading.astro";
import Btn from "@components/shared/Btn.astro";

interface Props {
  steps: HowItWorksStep[];
  heading: string;
  ctaHref: string;
  ctaText: string;
  ctaSubtext?: string | null;
  lang?: Locale;
}

const {
  steps,
  heading,
  ctaHref,
  ctaText,
  ctaSubtext,
  lang = DEFAULT_LOCALE,
} = Astro.props;

const stepLabel = t(lang, "howItWorks.stepLabel");
---

<section data-section="how-it-works" class="section">
  <div class="">
    <SectionHeading title={heading} />

    <ol class="grid w-full gap-4 md:grid-cols-3 md:gap-6">
      {
        steps.map((step, i) => (
          <li class="card card-body items-start">
            <span class="bg-brand/10 text-brand-darker rounded px-2 py-1 font-mono text-xs">
              <span class="sr-only">{stepLabel} </span>
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </li>
        ))
      }
    </ol>

    <!-- <div class="flex flex-col items-center gap-2">
      <Btn href={ctaHref} class="btn-solid">{ctaText}</Btn>
      {ctaSubtext && <p class="text-subtle text-sm">{ctaSubtext}</p>}
    </div> -->
  </div>
</section>
