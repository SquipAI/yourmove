---
import Base from "@layouts/Base.astro";
import PageHeading from "@components/ui/PageHeading.astro";
import ToolList from "@components/tools/ui/ToolList.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { AppPageData } from "@lib/types";

interface Props {
  app: AppPageData;
  lang?: Locale;
}

const { app, lang = DEFAULT_LOCALE } = Astro.props;
const count =
  app.tools.length === 1 ? t(lang, "tools.tool") : t(lang, "tools.tools");
---

<Base title={app.metaTitle} description={app.metaDescription} {lang}>
  <section class="section">
    <PageHeading
      title={app.title}
      subtitle={app.description ?? `${app.tools.length} ${count}`}
      size="big"
    />

    <ToolList tools={app.tools} {lang} level={2} />
  </section>
</Base>
