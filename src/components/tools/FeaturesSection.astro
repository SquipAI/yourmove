---
import type { Locale } from "@i18n/config";
import type { FeatureItem } from "@lib/types";
import { resolveNavHref } from "@lib/links";
import Icon from "@components/shared/Icon.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import Btn from "@components/shared/Btn.astro";

interface Props {
  items: FeatureItem[];
  heading: string;
  lang: Locale;
}

const { items, heading, lang } = Astro.props;
---

<section data-section="features" class="section">
  <div>
    <SectionHeading title={heading} />

    <ul class="grid w-full grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        items.map((item) => {
          const href = item.button
            ? resolveNavHref(
                item.button.link.targetType,
                item.button.link.targetSlug,
                item.button.link.externalUrl,
                lang,
              )
            : null;
          return (
            <li class="card flex flex-col gap-3 p-5 text-left md:p-6">
              <Icon name={item.icon} class="text-brand size-6" />
              <h3 class="text-lg font-semibold leading-tight">{item.title}</h3>
              <p class="text-subtle">{item.description}</p>
              {item.button && href && (
                <Btn href={href} class="btn-outline mt-auto self-start">
                  {item.button.text}
                </Btn>
              )}
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
