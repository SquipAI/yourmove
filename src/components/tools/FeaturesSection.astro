---
import type { Locale } from "@i18n/config";
import type { FeatureItem } from "@lib/types";
import { resolveNavHref } from "@lib/links";
import Icon from "@components/shared/Icon.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import Btn from "@components/shared/Btn.astro";

interface Props {
  items: FeatureItem[];
  heading: string;
  lang: Locale;
}

const { items, heading, lang } = Astro.props;
---

<section data-section="features" class="section">
  <div class="grid items-start lg:grid-cols-[1fr_1.6fr] lg:gap-x-section-xs">
    <SectionHeading title={heading} class="lg:sticky lg:top-24" />

    <ul class="divide-y divide-dark/10">
      {
        items.map((item) => {
          const href = item.button
            ? resolveNavHref(
                item.button.link.targetType,
                item.button.link.targetSlug,
                item.button.link.externalUrl,
                lang,
              )
            : null;
          return (
            <li class="flex items-start gap-x-4 py-5 first:pt-0 last:pb-0 sm:gap-x-5">
              <span class="bg-brand/10 text-brand-darker mt-0.5 rounded-lg p-2.5">
                <Icon name={item.icon} class="size-5" />
              </span>
              <div class="flex flex-col items-start gap-3">
                <div>
                  <h3 class="text-lg font-semibold leading-tight">
                    {item.title}
                  </h3>
                  <p class="text-subtle">{item.description}</p>
                </div>
                {item.button && href && (
                  <Btn href={href} variant="outline">
                    {item.button.text}
                  </Btn>
                )}
              </div>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
