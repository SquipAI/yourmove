---
import Eyebrow from "@components/shared/Eyebrow.astro";
import { parseAccent } from "@lib/parseAccent";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";

interface Props {
  currentRating: number;
  targetRating: number;
  verdict: string;
  breakdown: { label: string; score: number }[];
  actions: string[];
  lang: Locale;
}

const { currentRating, targetRating, verdict, breakdown, actions, lang } =
  Astro.props;

const pct = (score: number) =>
  `${Math.min(100, Math.max(0, (score / 10) * 100))}%`;
---

<article
  class="flex flex-col gap-6 bg-white rounded-lg border border-subtle-lighter shadow-xl shadow-brand/10 p-6 sm:p-8"
>
  <div class="flex flex-col gap-3">
    <div
      class="flex items-center justify-between text-subtle text-xs font-medium uppercase tracking-eyebrow"
    >
      <span>{t(lang, "reportPreview.currentRating")}</span>
      <span>{t(lang, "reportPreview.targetRating")}</span>
    </div>

    <div class="flex items-end justify-between gap-4">
      <p class="text-5xl font-semibold leading-none">
        {currentRating.toFixed(1)}<span class="text-xl text-subtle">/10</span>
      </p>
      <span class="text-subtle text-2xl" aria-hidden="true">→</span>
      <p class="text-5xl font-semibold leading-none text-brand-darker">
        {targetRating.toFixed(1)}<span class="text-xl text-subtle">/10</span>
      </p>
    </div>

    <div class="relative h-2 rounded-full bg-subtle-lighter">
      <div
        class="h-full rounded-full bg-brand"
        style={`width:${pct(currentRating)}`}
      >
      </div>
      <span
        class="absolute -top-1.5 w-1 h-5 bg-mist-800 rounded-full"
        style={`left:calc(${pct(targetRating)} - 2px)`}
        aria-hidden="true"></span>
    </div>
  </div>

  <p class="text-title-xs font-medium text-pretty">{verdict}</p>

  <ul class="flex flex-col gap-3">
    {
      breakdown.map((item) => (
        <li class="flex flex-col gap-1">
          <div class="flex items-baseline justify-between">
            <span class="font-medium">{item.label}</span>
            <span class="text-subtle text-sm">{item.score}/10</span>
          </div>
          <div class="h-1.5 rounded-full bg-subtle-lighter">
            <div
              class="h-full rounded-full bg-brand"
              style={`width:${pct(item.score)}`}
            />
          </div>
        </li>
      ))
    }
  </ul>

  <div class="flex flex-col gap-3 border-t border-subtle-lighter pt-6">
    <Eyebrow>
      {t(lang, "reportPreview.doThisNext")}
    </Eyebrow>

    <ol class="flex flex-col divide-y divide-subtle-lighter">
      {
        actions.map((action, i) => (
          <li class="flex items-start gap-3 py-3 first:pt-0 last:pb-0">
            <span class="flex shrink-0 items-center justify-center w-7 h-7 rounded-md bg-brand-lighter/25 text-brand-darker text-sm font-medium">
              {i + 1}
            </span>
            <p class="text-pretty pt-0.5">
              {parseAccent(action).map((part) =>
                part.accent ? (
                  <strong class="font-semibold">{part.text}</strong>
                ) : (
                  part.text
                ),
              )}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</article>
