---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "@i18n/config";
import type { ToolCard } from "@lib/types";
import CardHeading from "@components/blog/ui/CardHeading.astro";

interface Props {
  tool: ToolCard;
  lang: Locale;
  level?: 2 | 3;
}

const { tool, lang, level = 3 } = Astro.props;

const href = getRelativeLocaleUrl(lang, tool.slug);
const title = tool.cardTitle ?? tool.title;
const description = tool.cardDescription ?? tool.description;
---

<article class="card card-body">
  <CardHeading
    {title}
    {description}
    {href}
    {level}
    size="sm"
  />
</article>
