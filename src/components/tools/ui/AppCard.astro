---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type { AppWithTools } from "@lib/types";
import Eyebrow from "@components/shared/Eyebrow.astro";

interface Props {
  app: AppWithTools;
  lang: Locale;
  level?: 2 | 3;
}

const { app, lang, level = 3 } = Astro.props;
const HeadingTag = `h${level}` as "h2" | "h3";
const href = getRelativeLocaleUrl(lang, `tools/${app.slug}`);
const initial = app.name.charAt(0).toUpperCase();
const toolWord =
  app.toolCount === 1 ? t(lang, "tools.tool") : t(lang, "tools.tools");
const ctaLabel = t(lang, "tools.exploreAppTools").replace("{name}", app.name);
---

<article id={`app-${app.slug}`} class="card card-body">
  <header class="flex items-center gap-3">
    <span
      class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md text-base font-semibold text-white"
      style={`background-color: ${app.brandColor ?? "#6B7280"}`}
      aria-hidden="true"
    >
      {initial}
    </span>
    <hgroup>
      <HeadingTag class="text-title-xs">{app.name}</HeadingTag>
      <Eyebrow>{`${app.toolCount} ${toolWord}`}</Eyebrow>
    </hgroup>
  </header>

  {
    app.tools.length > 0 && (
      <ul class="text-subtle flex flex-col gap-1 text-sm">
        {app.tools.map((tool) => (
          <li>{tool.title}</li>
        ))}
      </ul>
    )
  }

  <a
    href={href}
    class="card-link text-brand group-hover:text-brand mt-auto text-sm font-medium"
  >
    {ctaLabel}
  </a>
</article>
