---
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import type {
  ToolsPageData,
  ToolCategoryWithTools,
  AppWithTools,
} from "@lib/types";
import Eyebrow from "@components/shared/Eyebrow.astro";
import PageHeading from "@components/shared/PageHeading.astro";
import ToolPills from "@components/tools/ui/ToolPills.astro";

interface Props {
  page: ToolsPageData;
  categories: ToolCategoryWithTools[];
  apps: AppWithTools[];
  lang: Locale;
}

const { page, categories, apps, lang } = Astro.props;

const toolCount = categories.reduce((sum, c) => sum + c.tools.length, 0);
const appCount = apps.length;
---

<section id="tools-top" class="section pb-0">
  <Eyebrow>
    {toolCount}
    {t(lang, "tools.tools")} · {appCount}
    {t(lang, "tools.apps")}
  </Eyebrow>

  <PageHeading
    title={page.title}
    subtitle={page.description}
    size="big"
    class="mb-section-sm"
  />

  <ToolPills {categories} {apps} {lang} totalTools={toolCount} />
</section>
