---
import { Image } from "astro:assets";

import avatar1 from "@assets/imgs/avatar-1.avif";
import avatar2 from "@assets/imgs/avatar-2.avif";
import avatar3 from "@assets/imgs/avatar-3.avif";

import { parseAccent } from "@lib/parseAccent";

interface Props {
  text?: string | null;
  class?: string;
}

const { text, class: cls } = Astro.props;
if (!text) return;
const parts = parseAccent(text);
const avatars = [avatar1, avatar2, avatar3];
---

<div
  class:list={[
    "bg-subtle-lighter flex items-center justify-center gap-3 rounded-xl px-svw py-2",
    cls,
  ]}
>
  <div class="shrink-0 flex -space-x-2">
    {
      avatars.map((src) => (
        <Image
          {src}
          alt=""
          width={32}
          height={32}
          loading="lazy"
          aria-hidden="true"
          class=" size-[24px] rounded-full border-[1.5px] border-brand/30"
        />
      ))
    }
  </div>
  <p class="text-sm sm:text-base lg:text-lg">
    {
      parts.map((p) =>
        p.accent ? <span class="accent">{p.text}</span> : p.text,
      )
    }
  </p>
</div>
